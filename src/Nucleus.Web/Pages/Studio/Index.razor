@page "/studio"
@attribute [Authorize]
@layout StudioLayout

<PageTitle>Studio Hub — Nucleus</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Studio</h1>
        <p class="page-subtitle">Design, build, and publish pages and visual assets for all your brands.</p>
    </div>
</div>

<div class="hub-feature-grid">
    <div class="hub-feature-card">
        <div class="hub-feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                <line x1="3"  y1="9"  x2="21" y2="9"/>
                <line x1="3"  y1="15" x2="21" y2="15"/>
                <line x1="9"  y1="9"  x2="9"  y2="21"/>
            </svg>
        </div>
        <div>
            <div class="hub-feature-name">Page Manager</div>
            <div class="hub-feature-desc">Manage all website pages per brand — create, edit, publish, and track performance.</div>
        </div>
    </div>
    <div class="hub-feature-card">
        <div class="hub-feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="3"/>
                <path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/>
            </svg>
        </div>
        <div>
            <div class="hub-feature-name">Design Studio</div>
            <div class="hub-feature-desc">AI-assisted HTML page builder with brand voice, color, and typography baked in.</div>
        </div>
    </div>
    <div class="hub-feature-card">
        <div class="hub-feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
            </svg>
        </div>
        <div>
            <div class="hub-feature-name">Image Generator</div>
            <div class="hub-feature-desc">Generate on-brand images with Flux — hero shots, blog headers, social graphics.</div>
        </div>
    </div>
    <div class="hub-feature-card">
        <div class="hub-feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
            </svg>
        </div>
        <div>
            <div class="hub-feature-name">Asset Library</div>
            <div class="hub-feature-desc">Central storage for all brand assets — images, documents, videos, and generated content.</div>
        </div>
    </div>
    <div class="hub-feature-card">
        <div class="hub-feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polygon points="23 7 16 12 23 17 23 7"/>
                <rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>
            </svg>
        </div>
        <div>
            <div class="hub-feature-name">Video Library</div>
            <div class="hub-feature-desc">Store and organize brand videos, including HeyGen AI spokesperson videos.</div>
        </div>
    </div>
    <div class="hub-feature-card">
        <div class="hub-feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
            </svg>
        </div>
        <div>
            <div class="hub-feature-name">HeyGen Integration</div>
            <div class="hub-feature-desc">Generate AI spokesperson videos with brand-specific avatars and scripts.</div>
        </div>
    </div>
</div>
