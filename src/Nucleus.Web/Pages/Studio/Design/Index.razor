@page "/studio/design"
@attribute [Authorize]
@layout StudioLayout
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Design Studio — Studio Hub — Nucleus</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Design Studio</h1>
        <p class="page-subtitle">AI-assisted HTML page builder. Describe your page and generate a brand-ready scaffold.</p>
    </div>
</div>

@if (_brands.Count == 0 && !_loading)
{
    <div class="empty-state">No brands yet. <a href="/brands">Add a brand</a> to use the Design Studio.</div>
}
else
{
    <div class="brand-pill-row">
        @foreach (var b in _brands)
        {
            <button class="brand-pill-btn @(_selectedBrand?.Id == b.Id ? "brand-pill-btn--active" : "")"
                    @onclick="() => SelectBrand(b)">
                <span class="brand-pill-dot" style="background:@b.PrimaryColor"></span>
                @b.Name
            </button>
        }
    </div>
}

@if (_error != null)
{
    <div class="alert-error">@_error</div>
}
@if (_successMsg != null)
{
    <div class="alert-success">@_successMsg</div>
}

@if (_selectedBrand != null)
{
    <!-- Studio Stats -->
    @if (_studioContext != null)
    {
        <div style="display:flex;gap:16px;flex-wrap:wrap;margin-bottom:24px;">
            <div class="stat-card stat-card--sm">
                <div class="stat-label">Total Pages</div>
                <div class="stat-value">@_studioContext.Stats.TotalPages</div>
            </div>
            <div class="stat-card stat-card--sm">
                <div class="stat-label">Published</div>
                <div class="stat-value" style="color:var(--hub-color)">@_studioContext.Stats.PublishedPages</div>
            </div>
            <div class="stat-card stat-card--sm">
                <div class="stat-label">Assets</div>
                <div class="stat-value">@_studioContext.Stats.TotalAssets</div>
            </div>
            <div class="stat-card stat-card--sm">
                <div class="stat-label">Generated Images</div>
                <div class="stat-value">@_studioContext.Stats.GeneratedImages</div>
            </div>
        </div>
    }

    <!-- AI Generator Card -->
    <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:12px;padding:28px;margin-bottom:24px;">
        <h2 style="font-size:16px;font-weight:700;margin-bottom:20px;display:flex;align-items:center;gap:8px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--hub-color)" stroke-width="2">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            AI Page Generator
        </h2>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
            <div class="form-group">
                <label class="form-label">Page Type</label>
                <select class="form-input" @bind="_genPageType">
                    <option value="landing">Landing Page</option>
                    <option value="service">Service Page</option>
                    <option value="homepage">Homepage</option>
                    <option value="blog">Blog Post</option>
                    <option value="other">Other</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Target Slug (optional)</label>
                <input type="text" class="form-input" @bind="_genSlug" placeholder="e.g. services/registration" />
            </div>
        </div>

        <div class="form-group" style="margin-bottom:16px;">
            <label class="form-label">Describe this page <span style="color:#ef4444;">*</span></label>
            <textarea class="form-input" rows="4" @bind="_genPrompt"
                      placeholder="e.g. A landing page for Montana vehicle registration services. Highlight speed, simplicity, and trust. Include a hero section, 3 feature cards, and a CTA button…"></textarea>
        </div>

        <button class="btn-hub" @onclick="GeneratePage" disabled="@_generating"
                style="width:100%;justify-content:center;padding:14px;">
            @if (_generating)
            {
                <div class="spinner" style="width:16px;height:16px;margin-right:8px;"></div>
                <span>Generating page&#8230;</span>
            }
            else
            {
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:8px;">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
                <span>Generate Page</span>
            }
        </button>

        @if (_generatedPage != null)
        {
            <div style="margin-top:20px;padding:16px;background:#f0fdf4;border:1px solid #86efac;border-radius:8px;">
                <p style="font-size:13px;font-weight:600;color:#166534;margin-bottom:8px;">
                    &#x2713; Page generated successfully!
                </p>
                <p style="font-size:12px;color:#166534;">
                    Saved as draft: <strong>/@_generatedPage.Slug</strong> &#8212; "@_generatedPage.Title"
                </p>
                <div style="display:flex;gap:8px;margin-top:12px;">
                    <a href="@($"/studio/pages/editor?id={_generatedPage.Id}")"
                       class="btn-hub" style="font-size:13px;text-decoration:none;">
                        Open Editor &#8594;
                    </a>
                    <a href="/studio/pages" class="btn-secondary" style="font-size:13px;text-decoration:none;">
                        View All Pages
                    </a>
                </div>
            </div>
        }
    </div>

    <!-- Recent Pages -->
    @if (_studioContext?.RecentPages.Count > 0)
    {
        <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:12px;padding:24px;margin-bottom:24px;">
            <h3 style="font-size:14px;font-weight:700;margin-bottom:16px;">Recent Pages</h3>
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:12px;">
                @foreach (var pg in _studioContext.RecentPages)
                {
                    <a href="@($"/studio/pages/editor?id={pg.Id}")"
                       style="display:block;padding:14px;border:1px solid var(--color-border);border-radius:8px;text-decoration:none;">
                        <div style="font-weight:600;font-size:13px;color:var(--color-text);margin-bottom:4px;">@pg.Title</div>
                        <div style="font-size:11px;font-family:monospace;color:var(--hub-color);">/@pg.Slug</div>
                        <div style="margin-top:8px;">
                            <span class="status-badge status-badge--@(pg.Status == "published" ? "success" : "muted")" style="font-size:10px;">
                                @pg.Status
                            </span>
                        </div>
                    </a>
                }
            </div>
        </div>
    }

    <!-- Recent Assets -->
    @if (_studioContext?.RecentAssets.Count > 0)
    {
        var imageAssets = _studioContext.RecentAssets.Where(a => a.AssetType is "image" or "generated").ToList();
        @if (imageAssets.Count > 0)
        {
            <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:12px;padding:24px;">
                <h3 style="font-size:14px;font-weight:700;margin-bottom:16px;">Recent Assets</h3>
                <div style="display:flex;gap:12px;flex-wrap:wrap;">
                    @foreach (var asset in imageAssets)
                    {
                        <div style="width:100px;text-align:center;">
                            <img src="@asset.Url" alt="@asset.Name"
                                 style="width:100px;height:70px;object-fit:cover;border-radius:6px;border:1px solid var(--color-border);" />
                            <p style="font-size:10px;color:var(--color-muted);margin-top:4px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@asset.Name</p>
                        </div>
                    }
                </div>
            </div>
        }
    }
}

@code {
    private List<BrandItem> _brands = [];
    private BrandItem? _selectedBrand;
    private StudioContext? _studioContext;
    private bool _loading, _generating;
    private string? _error, _successMsg;

    // Generator fields
    private string _genPageType = "landing";
    private string _genPrompt = "";
    private string? _genSlug;
    private GeneratedPage? _generatedPage;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiWrapper<List<BrandItem>>>("api/v1/brands");
            _brands = resp?.Data ?? [];
            if (_brands.Count > 0) await SelectBrand(_brands[0]);
        }
        finally { _loading = false; }
    }

    private async Task SelectBrand(BrandItem brand)
    {
        _selectedBrand = brand;
        _error = _successMsg = null;
        _generatedPage = null;
        await LoadContext();
    }

    private async Task LoadContext()
    {
        if (_selectedBrand is null) return;
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiWrapper<StudioContext>>(
                $"api/studio/design/context?brandId={_selectedBrand.Id}");
            _studioContext = resp?.Data;
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task GeneratePage()
    {
        if (_selectedBrand is null || string.IsNullOrWhiteSpace(_genPrompt)) return;
        _generating = true;
        _error = null;
        _successMsg = null;
        _generatedPage = null;
        try
        {
            var payload = new
            {
                BrandId = _selectedBrand.Id,
                PageType = _genPageType,
                Prompt = _genPrompt.Trim(),
                TargetSlug = string.IsNullOrWhiteSpace(_genSlug) ? (string?)null : _genSlug.Trim(),
            };
            var resp = await Http.PostAsJsonAsync("api/studio/design/generate", payload);
            if (resp.IsSuccessStatusCode)
            {
                var result = await resp.Content.ReadFromJsonAsync<ApiWrapper<GeneratedPage>>();
                _generatedPage = result?.Data;
                _successMsg = "Page generated!";
                await LoadContext();
            }
            else
            {
                _error = $"Generation failed: {await resp.Content.ReadAsStringAsync()}";
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _generating = false; }
    }

    // DTOs
    private class BrandItem
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = "";
        public string PrimaryColor { get; set; } = "#ec4899";
    }
    private class StudioContext
    {
        public Guid BrandId { get; set; }
        public string BrandName { get; set; } = "";
        public string? PrimaryColor { get; set; }
        public List<PageSummary> RecentPages { get; set; } = [];
        public List<AssetSummary> RecentAssets { get; set; } = [];
        public StudioStats Stats { get; set; } = new();
    }
    private class PageSummary
    {
        public Guid Id { get; set; }
        public string Slug { get; set; } = "";
        public string Title { get; set; } = "";
        public string PageType { get; set; } = "";
        public string Status { get; set; } = "";
    }
    private class AssetSummary
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = "";
        public string AssetType { get; set; } = "";
        public string Url { get; set; } = "";
    }
    private class StudioStats
    {
        public int TotalPages { get; set; }
        public int PublishedPages { get; set; }
        public int TotalAssets { get; set; }
        public int GeneratedImages { get; set; }
        public int TotalVideos { get; set; }
    }
    private class GeneratedPage
    {
        public Guid Id { get; set; }
        public string Slug { get; set; } = "";
        public string Title { get; set; } = "";
        public string Status { get; set; } = "";
    }
    private record ApiWrapper<T>(bool Success, T? Data);
}
