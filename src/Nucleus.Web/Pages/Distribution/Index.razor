@page "/distribution"
@attribute [Authorize]
@layout DistributionLayout

<PageTitle>Distribution Hub — Nucleus</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Distribution</h1>
        <p class="page-subtitle">Publish everywhere — social media, email, reviews, and beyond.</p>
    </div>
</div>

<div class="hub-feature-grid">
    <div class="hub-feature-card">
        <div class="hub-feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2"  x2="16" y2="6"/>
                <line x1="8"  y1="2"  x2="8"  y2="6"/>
                <line x1="3"  y1="10" x2="21" y2="10"/>
            </svg>
        </div>
        <div>
            <div class="hub-feature-name">Social Scheduler</div>
            <div class="hub-feature-desc">Schedule and publish posts across all social channels via GHL Social Planner.</div>
        </div>
    </div>
    <div class="hub-feature-card">
        <div class="hub-feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
            </svg>
        </div>
        <div>
            <div class="hub-feature-name">Email Blasts</div>
            <div class="hub-feature-desc">Send broadcast emails to brand contact lists via GHL or Drip, depending on brand config.</div>
        </div>
    </div>
    <div class="hub-feature-card">
        <div class="hub-feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
            </svg>
        </div>
        <div>
            <div class="hub-feature-name">Campaign Workspace</div>
            <div class="hub-feature-desc">Build multi-channel campaigns that coordinate email, social, and content in one view.</div>
        </div>
    </div>
    <div class="hub-feature-card">
        <div class="hub-feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
            </svg>
        </div>
        <div>
            <div class="hub-feature-name">Send Log</div>
            <div class="hub-feature-desc">Full audit trail of every email and social post sent — with delivery and open stats.</div>
        </div>
    </div>
    <div class="hub-feature-card">
        <div class="hub-feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
        </div>
        <div>
            <div class="hub-feature-name">Reviews Manager</div>
            <div class="hub-feature-desc">Sync and respond to Google and GHL reviews across all brand locations.</div>
        </div>
    </div>
    <div class="hub-feature-card">
        <div class="hub-feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
        </div>
        <div>
            <div class="hub-feature-name">GHL Contacts</div>
            <div class="hub-feature-desc">View and segment GHL contacts synced per brand for targeted campaigns.</div>
        </div>
    </div>
</div>
