@page "/authority"
@attribute [Authorize]
@layout AuthorityLayout

<PageTitle>Authority Hub — Nucleus</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Authority</h1>
        <p class="page-subtitle">Build domain authority through backlinks, brand mentions, and structured data.</p>
    </div>
</div>

<div class="hub-feature-grid">
    <div class="hub-feature-card">
        <div class="hub-feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
            </svg>
        </div>
        <div>
            <div class="hub-feature-name">Backlink Tracker</div>
            <div class="hub-feature-desc">Monitor inbound links to every brand domain — new, lost, and high-value links.</div>
        </div>
    </div>
    <div class="hub-feature-card">
        <div class="hub-feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
        </div>
        <div>
            <div class="hub-feature-name">Brand Mentions</div>
            <div class="hub-feature-desc">Track every mention of your brand across the web — linked and unlinked.</div>
        </div>
    </div>
    <div class="hub-feature-card">
        <div class="hub-feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
            </svg>
        </div>
        <div>
            <div class="hub-feature-name">Press Releases</div>
            <div class="hub-feature-desc">Draft, publish, and track press releases to earn high-authority coverage.</div>
        </div>
    </div>
    <div class="hub-feature-card">
        <div class="hub-feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="16 18 22 12 16 6"/>
                <polyline points="8 6 2 12 8 18"/>
            </svg>
        </div>
        <div>
            <div class="hub-feature-name">Schema Manager</div>
            <div class="hub-feature-desc">Auto-generate and deploy structured data by page type — Article, LocalBusiness, FAQ, and more.</div>
        </div>
    </div>
    <div class="hub-feature-card">
        <div class="hub-feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="22" y1="2" x2="11" y2="13"/>
                <polygon points="22 2 15 22 11 13 2 9 22 2"/>
            </svg>
        </div>
        <div>
            <div class="hub-feature-name">Outreach Queue</div>
            <div class="hub-feature-desc">Manage link-building and PR outreach campaigns with status tracking per prospect.</div>
        </div>
    </div>
    <div class="hub-feature-card">
        <div class="hub-feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <line x1="2"  y1="12" x2="22" y2="12"/>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
            </svg>
        </div>
        <div>
            <div class="hub-feature-name">Domain Analysis</div>
            <div class="hub-feature-desc">Compare domain authority, referring domains, and link velocity against competitors.</div>
        </div>
    </div>
</div>
