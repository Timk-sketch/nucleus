@page "/authority/backlinks"
@attribute [Authorize]
@layout AuthorityLayout
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Backlinks — Authority Hub — Nucleus</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Backlink Profile</h1>
        <p class="page-subtitle">Monitor inbound links — new, active, and lost — across your brand domains.</p>
    </div>
    <button class="btn-hub" @onclick="LoadProfile" disabled="@_loading">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <polyline points="23 4 23 10 17 10"/>
            <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
        </svg>
        Refresh
    </button>
</div>

@if (_brands.Count == 0 && !_loading)
{
    <div class="empty-state">No brands yet. <a href="/brands">Add a brand</a> to start tracking backlinks.</div>
}
else
{
    <div class="brand-pill-row">
        @foreach (var b in _brands)
        {
            <button class="brand-pill-btn @(_selectedBrand?.Id == b.Id ? "brand-pill-btn--active" : "")"
                    @onclick="() => SelectBrand(b)">
                <span class="brand-pill-dot" style="background:@b.PrimaryColor"></span>
                @b.Name
            </button>
        }
    </div>
}

@if (_error != null)
{
    <div class="alert-error">@_error</div>
}

@if (_selectedBrand != null)
{
    <!-- Summary Stats -->
    <div style="display:flex;gap:16px;flex-wrap:wrap;margin-bottom:24px;">
        <div class="stat-card stat-card--sm">
            <div class="stat-label">Total Backlinks</div>
            <div class="stat-value">@(_profile?.TotalBacklinks ?? 0)</div>
        </div>
        <div class="stat-card stat-card--sm">
            <div class="stat-label">Active</div>
            <div class="stat-value" style="color:var(--hub-color)">@(_profile?.ActiveBacklinks ?? 0)</div>
        </div>
        <div class="stat-card stat-card--sm">
            <div class="stat-label">Lost</div>
            <div class="stat-value" style="color:#ef4444">@(_profile?.LostBacklinks ?? 0)</div>
        </div>
        <div class="stat-card stat-card--sm">
            <div class="stat-label">New (30d)</div>
            <div class="stat-value">@(_profile?.NewLast30Days ?? 0)</div>
        </div>
        <div class="stat-card stat-card--sm">
            <div class="stat-label">Avg DR</div>
            <div class="stat-value">@(_profile?.AverageDomainRating.HasValue == true ? _profile.AverageDomainRating.Value.ToString("F1") : "—")</div>
        </div>
    </div>

    <!-- Filter row -->
    <div style="display:flex;gap:8px;margin-bottom:16px;align-items:center;flex-wrap:wrap;">
        <span style="font-size:13px;color:var(--color-muted);">Show:</span>
        <button class="brand-pill-btn @(!_activeOnly ? "brand-pill-btn--active" : "")"
                style="font-size:12px;padding:5px 12px;"
                @onclick="() => SetFilter(false)">All</button>
        <button class="brand-pill-btn @(_activeOnly ? "brand-pill-btn--active" : "")"
                style="font-size:12px;padding:5px 12px;"
                @onclick="() => SetFilter(true)">Active Only</button>
    </div>

    @if (_loading)
    {
        <div class="loading-state"><div class="spinner spinner--lg"></div></div>
    }
    else if (_profile?.Backlinks.Count == 0)
    {
        <div class="empty-state">
            No backlinks found for @_selectedBrand.Name.
            <p style="margin-top:8px;font-size:13px;color:var(--color-muted);">
                Backlinks are synced automatically. Use the API to import from DataForSEO.
            </p>
        </div>
    }
    else
    {
        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Source URL</th>
                        <th>Target URL</th>
                        <th>Anchor Text</th>
                        <th>DR</th>
                        <th>Status</th>
                        <th>First Seen</th>
                        <th>Last Seen</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var link in _profile!.Backlinks)
                    {
                        <tr>
                            <td style="max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                <a href="@link.SourceUrl" target="_blank" rel="noopener"
                                   style="color:var(--hub-color);font-size:12px;" title="@link.SourceUrl">
                                    @TruncateUrl(link.SourceUrl)
                                </a>
                            </td>
                            <td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:12px;color:var(--color-muted);" title="@link.TargetUrl">
                                @TruncateUrl(link.TargetUrl)
                            </td>
                            <td style="font-size:12px;max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                @(string.IsNullOrEmpty(link.AnchorText) ? "—" : link.AnchorText)
                            </td>
                            <td>
                                @if (link.DomainRating.HasValue)
                                {
                                    <span class="rank-badge rank-badge--@DrClass(link.DomainRating.Value)">
                                        @link.DomainRating.Value.ToString("F0")
                                    </span>
                                }
                                else
                                {
                                    <span style="color:var(--color-muted);">—</span>
                                }
                            </td>
                            <td>
                                <span class="status-badge status-badge--@(link.IsActive ? "success" : "danger")">
                                    @(link.IsActive ? "Active" : "Lost")
                                </span>
                            </td>
                            <td style="font-size:12px;color:var(--color-muted);">@link.FirstSeenAt.ToString("MMM d, yyyy")</td>
                            <td style="font-size:12px;color:var(--color-muted);">@link.LastSeenAt.ToString("MMM d, yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div style="display:flex;justify-content:space-between;align-items:center;margin-top:16px;">
            <span style="font-size:13px;color:var(--color-muted);">Page @_page</span>
            <div style="display:flex;gap:8px;">
                <button class="btn-secondary" @onclick="PrevPage" disabled="@(_page <= 1 || _loading)">← Prev</button>
                <button class="btn-secondary" @onclick="NextPage" disabled="@(_profile.Backlinks.Count < _pageSize || _loading)">Next →</button>
            </div>
        </div>
    }
}

@code {
    private List<BrandItem> _brands = [];
    private BrandItem? _selectedBrand;
    private BacklinkProfile? _profile;
    private bool _loading, _activeOnly;
    private string? _error;
    private int _page = 1, _pageSize = 50;

    protected override async Task OnInitializedAsync()
    {
        var resp = await Http.GetFromJsonAsync<ApiWrapper<List<BrandItem>>>("api/v1/brands");
        _brands = resp?.Data ?? [];
        if (_brands.Count > 0) await SelectBrand(_brands[0]);
    }

    private async Task SelectBrand(BrandItem brand)
    {
        _selectedBrand = brand;
        _page = 1;
        _error = null;
        await LoadProfile();
    }

    private async Task LoadProfile()
    {
        if (_selectedBrand is null) return;
        _loading = true;
        _profile = null;
        try
        {
            var url = $"api/authority/backlinks?brandId={_selectedBrand.Id}&activeOnly={_activeOnly}&page={_page}&pageSize={_pageSize}";
            var resp = await Http.GetFromJsonAsync<ApiWrapper<BacklinkProfile>>(url);
            _profile = resp?.Data;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private async Task SetFilter(bool activeOnly)
    {
        _activeOnly = activeOnly;
        _page = 1;
        await LoadProfile();
    }

    private async Task PrevPage()
    {
        if (_page <= 1) return;
        _page--;
        await LoadProfile();
    }

    private async Task NextPage()
    {
        _page++;
        await LoadProfile();
    }

    private static string TruncateUrl(string url)
    {
        if (url.Length <= 45) return url;
        try
        {
            var uri = new Uri(url);
            var path = uri.AbsolutePath.Length > 22 ? uri.AbsolutePath[..22] + "…" : uri.AbsolutePath;
            return uri.Host + path;
        }
        catch { return url[..42] + "…"; }
    }

    private static string DrClass(decimal dr) => dr switch
    {
        >= 70 => "top3",
        >= 40 => "top10",
        >= 20 => "top30",
        _ => "other",
    };

    // DTOs
    private class BrandItem { public Guid Id { get; set; } public string Name { get; set; } = ""; public string PrimaryColor { get; set; } = "#8b5cf6"; }
    private class BacklinkProfile
    {
        public Guid BrandId { get; set; }
        public string BrandName { get; set; } = "";
        public string? Domain { get; set; }
        public int TotalBacklinks { get; set; }
        public int ActiveBacklinks { get; set; }
        public int LostBacklinks { get; set; }
        public int NewLast30Days { get; set; }
        public decimal? AverageDomainRating { get; set; }
        public List<BacklinkRow> Backlinks { get; set; } = [];
    }
    private class BacklinkRow
    {
        public Guid Id { get; set; }
        public string SourceUrl { get; set; } = "";
        public string TargetUrl { get; set; } = "";
        public string? AnchorText { get; set; }
        public decimal? DomainRating { get; set; }
        public bool IsActive { get; set; }
        public DateTimeOffset FirstSeenAt { get; set; }
        public DateTimeOffset LastSeenAt { get; set; }
    }
    private record ApiWrapper<T>(bool Success, T? Data);
}
