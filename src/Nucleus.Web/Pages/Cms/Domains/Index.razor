@page "/cms/domains"
@attribute [Authorize]
@layout CmsLayout
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Domains — CMS Hub — Nucleus</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Custom Domains</h1>
        <p class="page-subtitle">Map custom hostnames to your brand sites and verify DNS.</p>
    </div>
    <button class="btn-hub" @onclick="OpenAddModal" disabled="@(_selectedBrand == null)">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Add Domain
    </button>
</div>

@if (_brands.Count == 0 && !_loading)
{
    <div class="empty-state">No brands yet. <a href="/brands">Add a brand</a> to map custom domains.</div>
}
else
{
    <div class="brand-pill-row">
        @foreach (var b in _brands)
        {
            <button class="brand-pill-btn @(_selectedBrand?.Id == b.Id ? "brand-pill-btn--active" : "")"
                    @onclick="() => SelectBrand(b)">
                <span class="brand-pill-dot" style="background:@b.PrimaryColor"></span>
                @b.Name
            </button>
        }
    </div>
}

@if (_error != null)
{
    <div class="alert-error">@_error</div>
}
@if (_successMsg != null)
{
    <div class="alert-success">@_successMsg</div>
}

@if (_selectedBrand != null)
{
    @if (_loading)
    {
        <div class="loading-state"><div class="spinner spinner--lg"></div></div>
    }
    else if (_domains.Count == 0)
    {
        <div class="empty-state">
            No domains mapped yet.
            <button class="btn-hub" style="margin-top:12px;" @onclick="OpenAddModal">
                Add first domain →
            </button>
        </div>
    }
    else
    {
        <!-- DNS verification instructions -->
        <div class="alert-info" style="background:var(--hub-color)11;border:1px solid var(--hub-color)33;border-radius:8px;padding:12px 16px;margin-bottom:20px;font-size:13px;">
            <strong>DNS Setup:</strong> Point your domain's CNAME or A record to
            <code style="background:#0001;padding:2px 6px;border-radius:4px;">nucleus-production.up.railway.app</code>
            then click Verify to confirm.
        </div>

        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Hostname</th>
                        <th>Primary</th>
                        <th>SSL Verified</th>
                        <th>Verified At</th>
                        <th>Added</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var dom in _domains)
                    {
                        <tr>
                            <td>
                                <span style="font-family:monospace;font-size:13px;font-weight:600;color:var(--hub-color);">
                                    @dom.Hostname
                                </span>
                            </td>
                            <td>
                                @if (dom.IsPrimary)
                                {
                                    <span class="status-badge status-badge--success">Primary</span>
                                }
                                else
                                {
                                    <span style="color:var(--color-muted);font-size:12px;">—</span>
                                }
                            </td>
                            <td>
                                @if (dom.SslVerified)
                                {
                                    <span class="status-badge status-badge--success">&#10003; Verified</span>
                                }
                                else
                                {
                                    <span class="status-badge status-badge--warning">Pending</span>
                                }
                            </td>
                            <td style="font-size:12px;color:var(--color-muted);">
                                @(dom.VerifiedAt.HasValue ? dom.VerifiedAt.Value.ToString("MMM d, yyyy") : "—")
                            </td>
                            <td style="font-size:12px;color:var(--color-muted);">
                                @dom.CreatedAt.ToString("MMM d, yyyy")
                            </td>
                            <td>
                                @if (!dom.SslVerified)
                                {
                                    <button class="btn-secondary" style="font-size:12px;padding:4px 10px;"
                                            @onclick="() => VerifyDomain(dom.Id)"
                                            disabled="@_verifying">
                                        @if (_verifying && _verifyingId == dom.Id) { <span>Checking…</span> }
                                        else { <span>Verify DNS</span> }
                                    </button>
                                }
                                else
                                {
                                    <span style="font-size:12px;color:var(--color-muted);">✓ Live</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

<!-- Add Domain Modal -->
@if (_showAddModal && _selectedBrand != null)
{
    <div class="modal-backdrop" @onclick="CloseAddModal">
        <div class="modal" style="max-width:500px;" @onclick:stopPropagation>
            <div class="modal-header">
                <h2 class="modal-title">Add Custom Domain</h2>
                <button class="modal-close" @onclick="CloseAddModal">&#x2715;</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label">Hostname <span style="color:#ef4444;">*</span></label>
                    <input type="text" class="form-input" @bind="_newHostname"
                           placeholder="e.g. www.example.com" />
                    <p style="font-size:11px;color:var(--color-muted);margin-top:4px;">
                        Enter the full hostname, e.g. <code>www.example.com</code> or <code>example.com</code>
                    </p>
                </div>
                <div class="form-group" style="display:flex;align-items:center;gap:8px;">
                    <input type="checkbox" id="isPrimary" @bind="_newIsPrimary" />
                    <label for="isPrimary" class="form-label" style="margin:0;cursor:pointer;">
                        Set as primary domain for this brand
                    </label>
                </div>
                @if (_modalError != null)
                {
                    <div class="alert-error" style="margin-top:8px;">@_modalError</div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" @onclick="CloseAddModal">Cancel</button>
                <button class="btn-hub" @onclick="SubmitAddDomain" disabled="@_submitting">
                    @if (_submitting) { <span>Adding…</span> } else { <span>Add Domain</span> }
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<BrandItem> _brands = [];
    private BrandItem? _selectedBrand;
    private List<DomainRow> _domains = [];
    private bool _loading, _submitting, _verifying;
    private Guid _verifyingId;
    private string? _error, _successMsg;

    // Add modal
    private bool _showAddModal;
    private string? _modalError;
    private string _newHostname = "";
    private bool _newIsPrimary;

    protected override async Task OnInitializedAsync()
    {
        var resp = await Http.GetFromJsonAsync<ApiWrapper<List<BrandItem>>>("api/v1/brands");
        _brands = resp?.Data ?? [];
        if (_brands.Count > 0) await SelectBrand(_brands[0]);
    }

    private async Task SelectBrand(BrandItem brand)
    {
        _selectedBrand = brand;
        _error = _successMsg = null;
        await LoadDomains();
    }

    private async Task LoadDomains()
    {
        if (_selectedBrand is null) return;
        _loading = true;
        _domains = [];
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiWrapper<List<DomainRow>>>(
                $"api/cms/domains?brandId={_selectedBrand.Id}");
            _domains = resp?.Data ?? [];
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private async Task VerifyDomain(Guid domainId)
    {
        _error = _successMsg = null;
        _verifying = true;
        _verifyingId = domainId;
        try
        {
            var resp = await Http.PostAsJsonAsync($"api/cms/domains/{domainId}/verify", new { });
            if (resp.IsSuccessStatusCode)
            {
                _successMsg = "Domain verified successfully!";
                await LoadDomains();
            }
            else
            {
                _error = $"Verification failed: {await resp.Content.ReadAsStringAsync()}";
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _verifying = false; _verifyingId = Guid.Empty; }
    }

    private void OpenAddModal()
    {
        _newHostname = "";
        _newIsPrimary = false;
        _modalError = null;
        _showAddModal = true;
    }

    private void CloseAddModal()
    {
        _showAddModal = false;
        _modalError = null;
    }

    private async Task SubmitAddDomain()
    {
        if (_selectedBrand is null) return;
        _modalError = null;

        if (string.IsNullOrWhiteSpace(_newHostname))
        {
            _modalError = "Hostname is required.";
            return;
        }

        _submitting = true;
        try
        {
            var resp = await Http.PostAsJsonAsync("api/cms/domains", new
            {
                BrandId = _selectedBrand.Id,
                Hostname = _newHostname.Trim().ToLower(),
                IsPrimary = _newIsPrimary,
            });

            if (resp.IsSuccessStatusCode)
            {
                _successMsg = $"Domain '{_newHostname}' added. Set up DNS then click Verify DNS.";
                _showAddModal = false;
                await LoadDomains();
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                _modalError = $"Failed: {body}";
            }
        }
        catch (Exception ex) { _modalError = ex.Message; }
        finally { _submitting = false; }
    }

    // ── DTOs ─────────────────────────────────────────────────────────────────

    private class BrandItem
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = "";
        public string PrimaryColor { get; set; } = "#0ea5e9";
    }

    private class DomainRow
    {
        public Guid Id { get; set; }
        public string Hostname { get; set; } = "";
        public bool IsPrimary { get; set; }
        public bool SslVerified { get; set; }
        public DateTimeOffset? VerifiedAt { get; set; }
        public DateTimeOffset CreatedAt { get; set; }
    }

    private record ApiWrapper<T>(bool Success, T? Data);
}
