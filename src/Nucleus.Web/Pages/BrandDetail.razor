@page "/brands/{Id:guid}"
@attribute [Authorize]
@using Microsoft.AspNetCore.SignalR.Client
@inject HttpClient Http
@inject IConfiguration Config
@inject NavigationManager Nav
@inject Nucleus.Web.Services.AuthService AuthService
@implements IAsyncDisposable

<PageTitle>@(_brand?.Name ?? "Brand") — Nucleus</PageTitle>

@if (_loading)
{
    <div class="loading-state">
        <div class="spinner spinner--lg"></div>
        <p>Loading brand…</p>
    </div>
}
else if (_brand == null)
{
    <div class="error-state">
        <p>Brand not found.</p>
        <a href="/brands" class="btn-secondary">Back to brands</a>
    </div>
}
else
{
    <div class="page-header">
        <div style="display:flex;align-items:center;gap:14px;">
            <div style="width:14px;height:14px;border-radius:50%;background:@_brand.PrimaryColor;flex-shrink:0;"></div>
            <div>
                <h1 class="page-title">@_brand.Name</h1>
                <p class="page-subtitle">@_brand.Domain · @_brand.Code</p>
            </div>
        </div>
        <div style="display:flex;align-items:center;gap:12px;">
            <span class="brand-status brand-status--@_brand.Status">@_brand.Status</span>
            <a href="/brands/@_brand.Id/edit" class="btn-secondary" style="font-size:13px;padding:6px 14px;">Edit</a>
        </div>
    </div>

    <div class="section-header">
        <span class="section-title">Provisioning</span>
    </div>

    <div style="display:flex;flex-direction:column;gap:8px;max-width:560px;">
        @foreach (var step in _steps)
        {
            <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius);
                        padding:14px 18px;display:flex;align-items:center;gap:14px;">
                @StepIcon(step.Status)
                <div style="flex:1;">
                    <div style="font-weight:600;text-transform:capitalize;">@step.StepName</div>
                    @if (step.ErrorMessage != null)
                    {
                        <div style="font-size:12px;color:var(--color-red);margin-top:2px;">@step.ErrorMessage</div>
                    }
                </div>
                <span style="font-size:12px;font-weight:600;padding:2px 8px;border-radius:999px;
                             background:@StepBadgeBg(step.Status);color:@StepBadgeColor(step.Status);">
                    @step.Status
                </span>
            </div>
        }
    </div>

    @if (_brand.Status == "active")
    {
        <div style="margin-top:24px;padding:16px 20px;background:rgba(16,185,129,0.08);
                    border:1px solid rgba(16,185,129,0.2);border-radius:var(--radius);
                    display:flex;align-items:center;gap:12px;max-width:560px;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2">
                <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span style="color:#10b981;font-weight:600;">Brand is fully provisioned and active.</span>
        </div>
    }
}

@code {
    [Parameter] public Guid Id { get; set; }

    private BrandDto? _brand;
    private List<StepDto> _steps = [];
    private bool _loading = true;
    private HubConnection? _hub;

    protected override async Task OnInitializedAsync()
    {
        await LoadBrand();
        if (_brand != null && _brand.Status != "active")
            await ConnectSignalR();
    }

    private async Task LoadBrand()
    {
        _loading = true;
        try
        {
            var resp = await Http.GetFromJsonAsync<BrandDetailResponse>($"api/v1/brands/{Id}");
            if (resp?.Data != null)
            {
                _brand = resp.Data;
                _steps = resp.Data.ProvisioningSteps ?? [];
            }
        }
        catch { /* brand not found */ }
        finally { _loading = false; }
    }

    private async Task ConnectSignalR()
    {
        var token = await AuthService.GetAccessTokenAsync();
        var baseUrl = Config["ApiBaseUrl"]?.TrimEnd('/') ?? Http.BaseAddress?.ToString().TrimEnd('/') ?? "";

        _hub = new HubConnectionBuilder()
            .WithUrl($"{baseUrl}/hubs/provisioning", opts =>
            {
                opts.AccessTokenProvider = () => Task.FromResult<string?>(token);
            })
            .WithAutomaticReconnect()
            .Build();

        _hub.On<StepUpdate>("StepUpdated", update =>
        {
            var existing = _steps.FirstOrDefault(s => s.StepName == update.StepName);
            if (existing != null)
            {
                existing.Status = update.Status;
                existing.ErrorMessage = update.ErrorMessage;
            }
            InvokeAsync(StateHasChanged);
        });

        _hub.On<Guid>("BrandActivated", _ =>
        {
            if (_brand != null) _brand.Status = "active";
            InvokeAsync(StateHasChanged);
        });

        try
        {
            await _hub.StartAsync();
            await _hub.InvokeAsync("Subscribe", Id.ToString());
        }
        catch { /* SignalR optional — page still works without real-time */ }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hub != null)
        {
            await _hub.InvokeAsync("Unsubscribe", Id.ToString());
            await _hub.DisposeAsync();
        }
    }

    // ── Icon helpers ────────────────────────────────────────────────────────
    private RenderFragment StepIcon(string status) => status switch
    {
        "completed" => @<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>,
        "running"   => @<div class="spinner" style="border-color:rgba(99,102,241,0.3);border-top-color:var(--color-accent);"></div>,
        "failed"    => @<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>,
        _           => @<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2"><circle cx="12" cy="12" r="9"/></svg>,
    };

    private static string StepBadgeBg(string s) => s switch
    {
        "completed" => "rgba(16,185,129,0.12)",
        "running"   => "rgba(99,102,241,0.12)",
        "failed"    => "rgba(239,68,68,0.12)",
        _           => "rgba(148,163,184,0.12)",
    };

    private static string StepBadgeColor(string s) => s switch
    {
        "completed" => "#10b981",
        "running"   => "#6366f1",
        "failed"    => "#ef4444",
        _           => "#94a3b8",
    };

    // ── DTOs ────────────────────────────────────────────────────────────────
    private class BrandDto
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = "";
        public string Domain { get; set; } = "";
        public string Code { get; set; } = "";
        public string PrimaryColor { get; set; } = "#6366f1";
        public string Status { get; set; } = "";
        public List<StepDto>? ProvisioningSteps { get; set; }
    }

    private class StepDto
    {
        public string StepName { get; set; } = "";
        public string Status { get; set; } = "pending";
        public string? ErrorMessage { get; set; }
    }

    private record StepUpdate(string StepName, string Status, string? ErrorMessage);
    private record BrandDetailResponse(bool Success, BrandDto? Data);
}
