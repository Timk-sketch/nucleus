@page "/search/history"
@attribute [Authorize]
@layout SearchLayout
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Rank History — Search Hub — Nucleus</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Rank History</h1>
        <p class="page-subtitle">90-day position chart for every tracked keyword.</p>
    </div>
</div>

<!-- Brand selector -->
@if (_brands.Count == 0 && !_brandsLoading)
{
    <div class="empty-state">No brands yet. <a href="/brands">Add a brand</a> to get started.</div>
}
else
{
    <div class="brand-pill-row">
        @foreach (var b in _brands)
        {
            <button class="brand-pill-btn @(_selectedBrand?.Id == b.Id ? "brand-pill-btn--active" : "")"
                    @onclick="() => SelectBrand(b)">
                <span class="brand-pill-dot" style="background:@b.PrimaryColor"></span>
                @b.Name
            </button>
        }
    </div>
}

@if (_selectedBrand != null)
{
    <!-- Keyword selector -->
    @if (_keywords.Count == 0 && !_kwLoading)
    {
        <div class="empty-state">
            No keywords tracked for this brand.
            <a href="/content">Add keywords in Content Hub →</a>
        </div>
    }
    else
    {
        <div style="margin-bottom:20px;max-width:400px;">
            <label style="font-size:11px;font-weight:700;letter-spacing:.05em;color:var(--color-muted);text-transform:uppercase;display:block;margin-bottom:6px;">
                Select Keyword
            </label>
            <select class="form-input" @onchange="OnKeywordChange" style="max-width:400px;">
                <option value="">— choose a keyword —</option>
                @foreach (var kw in _keywords)
                {
                    <option value="@kw.Id">@kw.Keyword</option>
                }
            </select>
        </div>
    }

    @if (_historyLoading)
    {
        <div class="loading-state"><div class="spinner spinner--lg"></div></div>
    }
    else if (_history != null)
    {
        <div class="card" style="padding:24px;margin-bottom:24px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;flex-wrap:wrap;gap:8px;">
                <h2 style="font-size:16px;font-weight:700;margin:0;">@_history.Keyword</h2>
                @if (!string.IsNullOrEmpty(_history.TargetUrl))
                {
                    <a href="@_history.TargetUrl" target="_blank" rel="noopener"
                       style="font-size:13px;color:var(--hub-color);">Target: @_history.TargetUrl</a>
                }
            </div>

            @if (_history.History.Count == 0)
            {
                <div class="empty-state">No rank history yet. Trigger a rank check to start collecting data.</div>
            }
            else
            {
                <!-- Simple ASCII-style chart using CSS -->
                <div style="overflow-x:auto;">
                    <div style="min-width:600px;">
                        <!-- Chart area -->
                        <div style="position:relative;height:200px;background:rgba(0,0,0,0.02);border:1px solid var(--color-border);border-radius:8px;padding:16px 8px 8px;margin-bottom:8px;">
                            @{
                                var nonNull = _history.History.Where(h => h.Position.HasValue).ToList();
                                var maxPos = nonNull.Count > 0 ? nonNull.Max(h => h.Position!.Value) : 100;
                                var minPos = nonNull.Count > 0 ? nonNull.Min(h => h.Position!.Value) : 1;
                                maxPos = Math.Max(maxPos + 5, 10);
                                minPos = Math.Max(minPos - 2, 1);
                                var range = maxPos - minPos + 1;
                                var total = _history.History.Count;
                            }
                            <svg width="100%" height="168" viewBox="0 0 @(total * 20) 168" preserveAspectRatio="none">
                                <!-- Horizontal guide lines -->
                                <line x1="0" y1="0" x2="@(total * 20)" y2="0" stroke="var(--color-border)" stroke-width="0.5"/>
                                <line x1="0" y1="84" x2="@(total * 20)" y2="84" stroke="var(--color-border)" stroke-width="0.5" stroke-dasharray="4"/>
                                <line x1="0" y1="168" x2="@(total * 20)" y2="168" stroke="var(--color-border)" stroke-width="0.5"/>

                                @{
                                    // Build polyline points
                                    var pts = new System.Text.StringBuilder();
                                    for (int i = 0; i < _history.History.Count; i++)
                                    {
                                        var h = _history.History[i];
                                        if (!h.Position.HasValue) continue;
                                        var x = i * 20 + 10;
                                        // Lower position = higher on chart (better rank)
                                        var y = (int)(((double)(h.Position.Value - minPos) / range) * 168);
                                        y = Math.Max(4, Math.Min(164, y));
                                        pts.Append($"{x},{y} ");
                                    }
                                    var polyPoints = pts.ToString().Trim();
                                }

                                @if (!string.IsNullOrEmpty(polyPoints))
                                {
                                    <polyline points="@polyPoints"
                                              fill="none"
                                              stroke="var(--hub-color)"
                                              stroke-width="2"
                                              stroke-linejoin="round"
                                              stroke-linecap="round"/>

                                    @for (int i = 0; i < _history.History.Count; i++)
                                    {
                                        var h = _history.History[i];
                                        if (!h.Position.HasValue) continue;
                                        var x = i * 20 + 10;
                                        var y = (int)(((double)(h.Position.Value - minPos) / range) * 168);
                                        y = Math.Max(4, Math.Min(164, y));
                                        <circle cx="@x" cy="@y" r="3" fill="var(--hub-color)">
                                            <title>@h.CheckedAt.ToString("MMM d"): #@h.Position</title>
                                        </circle>
                                    }
                                }
                            </svg>
                        </div>

                        <!-- X-axis labels: show every 7th date -->
                        <div style="display:flex;justify-content:space-between;font-size:10px;color:var(--color-muted);padding:0 8px;">
                            @for (int i = 0; i < _history.History.Count; i += Math.Max(1, _history.History.Count / 7))
                            {
                                <span>@_history.History[i].CheckedAt.ToString("MMM d")</span>
                            }
                        </div>
                    </div>
                </div>

                <!-- Data table -->
                <div style="margin-top:20px;max-height:300px;overflow-y:auto;">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Position</th>
                                <th>Ranked URL</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var h in _history.History.OrderByDescending(x => x.CheckedAt))
                            {
                                <tr>
                                    <td style="font-size:13px;">@h.CheckedAt.ToString("MMM d, yyyy HH:mm")</td>
                                    <td>
                                        @if (h.Position.HasValue)
                                        {
                                            <span class="rank-badge rank-badge--@(h.Position <= 3 ? "top3" : h.Position <= 10 ? "top10" : h.Position <= 30 ? "top30" : "other")">#@h.Position</span>
                                        }
                                        else { <span style="color:var(--color-muted);">Not ranking</span> }
                                    </td>
                                    <td style="font-size:12px;">
                                        @if (!string.IsNullOrEmpty(h.RankedUrl))
                                        {
                                            <a href="@h.RankedUrl" target="_blank" rel="noopener"
                                               style="color:var(--hub-color);">@(h.RankedUrl.Length > 50 ? h.RankedUrl[..50] + "…" : h.RankedUrl)</a>
                                        }
                                        else { <span style="color:var(--color-muted);">—</span> }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }
}

@code {
    [SupplyParameterFromQuery] public Guid? KeywordId { get; set; }

    private List<BrandItem> _brands = [];
    private BrandItem? _selectedBrand;
    private List<KeywordItem> _keywords = [];
    private HistoryData? _history;
    private bool _brandsLoading = true, _kwLoading, _historyLoading;

    protected override async Task OnInitializedAsync()
    {
        var resp = await Http.GetFromJsonAsync<ApiWrapper<List<BrandItem>>>("api/v1/brands");
        _brands = resp?.Data ?? [];
        _brandsLoading = false;

        if (_brands.Count > 0)
            await SelectBrand(_brands[0]);
    }

    protected override async Task OnParametersSetAsync()
    {
        if (KeywordId.HasValue && _keywords.Count > 0)
        {
            var kw = _keywords.FirstOrDefault(k => k.Id == KeywordId.Value);
            if (kw != null)
                await LoadHistory(kw.Id);
        }
    }

    private async Task SelectBrand(BrandItem brand)
    {
        _selectedBrand = brand;
        _history = null;
        _kwLoading = true;
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiWrapper<List<KeywordItem>>>(
                $"api/v1/brands/{brand.Id}/keywords");
            _keywords = resp?.Data ?? [];

            if (KeywordId.HasValue)
            {
                var kw = _keywords.FirstOrDefault(k => k.Id == KeywordId.Value);
                if (kw != null)
                    await LoadHistory(kw.Id);
            }
        }
        finally { _kwLoading = false; }
    }

    private async Task OnKeywordChange(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out var id))
            await LoadHistory(id);
    }

    private async Task LoadHistory(Guid keywordId)
    {
        _historyLoading = true;
        _history = null;
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiWrapper<HistoryData>>(
                $"api/search/history/{keywordId}?days=90");
            _history = resp?.Data;
        }
        finally { _historyLoading = false; }
    }

    // DTOs
    private class BrandItem { public Guid Id { get; set; } public string Name { get; set; } = ""; public string PrimaryColor { get; set; } = "#6366f1"; }
    private class KeywordItem { public Guid Id { get; set; } public string Keyword { get; set; } = ""; public string? TargetUrl { get; set; } }
    private class HistoryData
    {
        public Guid KeywordId { get; set; }
        public string Keyword { get; set; } = "";
        public string? TargetUrl { get; set; }
        public List<HistoryPoint> History { get; set; } = [];
    }
    private class HistoryPoint { public DateTimeOffset CheckedAt { get; set; } public int? Position { get; set; } public string? RankedUrl { get; set; } }
    private record ApiWrapper<T>(bool Success, T? Data);
}
