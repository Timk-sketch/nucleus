@page "/search/performance"
@attribute [Authorize]
@layout SearchLayout
@inject HttpClient Http

<PageTitle>Page Performance — Search Hub — Nucleus</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Page Performance</h1>
        <p class="page-subtitle">See which pages are driving search visibility — grouped by ranked URL.</p>
    </div>
</div>

<!-- Brand selector -->
@if (_brands.Count == 0 && !_brandsLoading)
{
    <div class="empty-state">No brands yet. <a href="/brands">Add a brand</a> to get started.</div>
}
else
{
    <div class="brand-pill-row">
        @foreach (var b in _brands)
        {
            <button class="brand-pill-btn @(_selectedBrand?.Id == b.Id ? "brand-pill-btn--active" : "")"
                    @onclick="() => SelectBrand(b)">
                <span class="brand-pill-dot" style="background:@b.PrimaryColor"></span>
                @b.Name
            </button>
        }
    </div>
}

@if (_selectedBrand != null)
{
    @if (_loading)
    {
        <div class="loading-state"><div class="spinner spinner--lg"></div></div>
    }
    else if (_pages.Count == 0)
    {
        <div class="empty-state">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--hub-color)" stroke-width="1.5" style="margin-bottom:12px;opacity:0.5;">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="17 8 12 3 7 8"/>
                <line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
            <div>No page performance data yet. <a href="/search/rankings">Check ranks first →</a></div>
        </div>
    }
    else
    {
        <div style="display:flex;gap:16px;margin-bottom:24px;flex-wrap:wrap;">
            <div class="stat-card stat-card--sm">
                <div class="stat-label">Pages Ranking</div>
                <div class="stat-value" style="color:var(--hub-color);">@_pages.Count</div>
            </div>
            <div class="stat-card stat-card--sm">
                <div class="stat-label">Best Avg Position</div>
                <div class="stat-value">@(_pages.Count > 0 ? _pages.Min(p => p.AveragePosition).ToString("F1") : "—")</div>
            </div>
            <div class="stat-card stat-card--sm">
                <div class="stat-label">Total Keywords</div>
                <div class="stat-value">@_pages.Sum(p => p.KeywordCount)</div>
            </div>
        </div>

        <div style="display:grid;gap:12px;">
            @foreach (var pg in _pages)
            {
                <div class="card" style="padding:20px;">
                    <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;margin-bottom:12px;flex-wrap:wrap;">
                        <div style="flex:1;min-width:0;">
                            <a href="@pg.Url" target="_blank" rel="noopener"
                               style="font-weight:700;font-size:14px;color:var(--hub-color);word-break:break-all;">@pg.Url</a>
                        </div>
                        <div style="display:flex;gap:16px;flex-shrink:0;">
                            <div style="text-align:center;">
                                <div style="font-size:11px;color:var(--color-muted);text-transform:uppercase;letter-spacing:.05em;">Best</div>
                                <div class="rank-badge rank-badge--@RankClass(pg.BestPosition)">#@pg.BestPosition</div>
                            </div>
                            <div style="text-align:center;">
                                <div style="font-size:11px;color:var(--color-muted);text-transform:uppercase;letter-spacing:.05em;">Avg</div>
                                <div style="font-size:16px;font-weight:700;">#@pg.AveragePosition.ToString("F0")</div>
                            </div>
                            <div style="text-align:center;">
                                <div style="font-size:11px;color:var(--color-muted);text-transform:uppercase;letter-spacing:.05em;">Keywords</div>
                                <div style="font-size:16px;font-weight:700;">@pg.KeywordCount</div>
                            </div>
                        </div>
                    </div>

                    @if (pg.TopKeywords.Count > 0)
                    {
                        <div style="display:flex;flex-wrap:wrap;gap:6px;">
                            @foreach (var kw in pg.TopKeywords)
                            {
                                <span style="padding:3px 10px;background:color-mix(in srgb, var(--hub-color) 10%, transparent);color:var(--hub-color);border-radius:999px;font-size:12px;font-weight:600;">
                                    @kw
                                </span>
                            }
                        </div>
                    }

                    @if (pg.TotalSearchVolume.HasValue && pg.TotalSearchVolume > 0)
                    {
                        <div style="font-size:12px;color:var(--color-muted);margin-top:8px;">
                            Total search volume: @FormatVolume(pg.TotalSearchVolume.Value)
                        </div>
                    }
                </div>
            }
        </div>

        <div style="margin-top:16px;padding:14px 16px;background:rgba(0,0,0,0.03);border-radius:8px;font-size:12px;color:var(--color-muted);">
            Based on last 30 days of rank check data. Connect Google Search Console for impressions and CTR data.
        </div>
    }
}

@code {
    private List<BrandItem> _brands = [];
    private BrandItem? _selectedBrand;
    private List<PageItem> _pages = [];
    private bool _brandsLoading = true, _loading;

    protected override async Task OnInitializedAsync()
    {
        var resp = await Http.GetFromJsonAsync<ApiWrapper<List<BrandItem>>>("api/v1/brands");
        _brands = resp?.Data ?? [];
        _brandsLoading = false;
        if (_brands.Count > 0) await SelectBrand(_brands[0]);
    }

    private async Task SelectBrand(BrandItem brand)
    {
        _selectedBrand = brand;
        await LoadPerformance();
    }

    private async Task LoadPerformance()
    {
        if (_selectedBrand is null) return;
        _loading = true;
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiWrapper<List<PageItem>>>(
                $"api/search/performance?brandId={_selectedBrand.Id}");
            _pages = resp?.Data ?? [];
        }
        finally { _loading = false; }
    }

    private static string RankClass(int pos) => pos switch
    {
        <= 3 => "top3",
        <= 10 => "top10",
        <= 30 => "top30",
        _ => "other",
    };

    private static string FormatVolume(int vol) => vol switch
    {
        >= 1000000 => $"{vol / 1000000}M",
        >= 1000 => $"{vol / 1000}k",
        _ => vol.ToString(),
    };

    // DTOs
    private class BrandItem { public Guid Id { get; set; } public string Name { get; set; } = ""; public string PrimaryColor { get; set; } = "#6366f1"; }
    private class PageItem
    {
        public string Url { get; set; } = "";
        public int KeywordCount { get; set; }
        public double AveragePosition { get; set; }
        public int BestPosition { get; set; }
        public int? TotalSearchVolume { get; set; }
        public List<string> TopKeywords { get; set; } = [];
    }
    private record ApiWrapper<T>(bool Success, T? Data);
}
