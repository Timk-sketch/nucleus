@page "/company"
@attribute [Authorize]
@inject HttpClient Http

<PageTitle>Company — Nucleus</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Company settings</h1>
        <p class="page-subtitle">Manage your workspace and plan</p>
    </div>
</div>

@if (_loading)
{
    <div class="loading-state"><div class="spinner spinner--lg"></div></div>
}
else
{
    <div style="max-width:560px;display:flex;flex-direction:column;gap:24px;">

        <!-- Workspace -->
        <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius);padding:28px;">
            <div class="section-header" style="margin-top:0;">
                <span class="section-title">Workspace</span>
            </div>

            @if (_error != null)
            {
                <div class="auth-error" style="margin-bottom:16px;">@_error</div>
            }
            @if (_saved)
            {
                <div style="margin-bottom:16px;padding:12px 16px;background:rgba(16,185,129,0.08);
                            border:1px solid rgba(16,185,129,0.2);border-radius:var(--radius);
                            color:#10b981;font-weight:600;">Changes saved.</div>
            }

            <div class="form-group">
                <label>COMPANY NAME</label>
                <input class="form-input" @bind="_name" placeholder="Acme Corp" disabled="@(!_isAdmin)" />
            </div>

            <div class="form-group">
                <label>SLUG</label>
                <input class="form-input" value="@_slug" disabled
                       style="opacity:0.6;cursor:not-allowed;font-family:monospace;" />
                <span style="font-size:12px;color:var(--color-muted);margin-top:4px;display:block;">
                    Auto-generated from company name
                </span>
            </div>

            @if (_isAdmin)
            {
                <button class="btn-primary" @onclick="Save" disabled="@_saving" style="margin-top:8px;">
                    @(_saving ? "Saving…" : "Save changes")
                </button>
            }
        </div>

        <!-- Plan -->
        <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius);padding:28px;">
            <div class="section-header" style="margin-top:0;">
                <span class="section-title">Plan</span>
            </div>

            <div style="display:flex;align-items:center;justify-content:space-between;
                        padding:16px;border:1px solid var(--color-border);border-radius:var(--radius);">
                <div>
                    <div style="font-weight:700;text-transform:capitalize;">@_plan</div>
                    <div style="font-size:13px;color:var(--color-muted);margin-top:2px;">
                        @_brandCount brand@(_brandCount != 1 ? "s" : "") · @_userCount user@(_userCount != 1 ? "s" : "")
                    </div>
                </div>
                <span style="font-size:12px;padding:4px 12px;border-radius:999px;
                             background:rgba(99,102,241,0.1);color:#6366f1;font-weight:700;
                             text-transform:uppercase;letter-spacing:.05em;">@_plan</span>
            </div>

            <p style="font-size:13px;color:var(--color-muted);margin-top:16px;">
                Billing and plan upgrades coming soon.
            </p>
        </div>

        <!-- Workspace info -->
        <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius);padding:28px;">
            <div class="section-header" style="margin-top:0;">
                <span class="section-title">Workspace info</span>
            </div>

            <dl style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin:0;">
                <div>
                    <dt style="font-size:11px;font-weight:700;letter-spacing:.05em;color:var(--color-muted);text-transform:uppercase;">Created</dt>
                    <dd style="margin:4px 0 0;font-size:14px;">@_createdAt.ToString("MMM d, yyyy")</dd>
                </div>
                <div>
                    <dt style="font-size:11px;font-weight:700;letter-spacing:.05em;color:var(--color-muted);text-transform:uppercase;">Workspace ID</dt>
                    <dd style="margin:4px 0 0;font-size:12px;font-family:monospace;color:var(--color-muted);">@_tenantId</dd>
                </div>
                <div>
                    <dt style="font-size:11px;font-weight:700;letter-spacing:.05em;color:var(--color-muted);text-transform:uppercase;">Brands</dt>
                    <dd style="margin:4px 0 0;font-size:14px;font-weight:700;">@_brandCount</dd>
                </div>
                <div>
                    <dt style="font-size:11px;font-weight:700;letter-spacing:.05em;color:var(--color-muted);text-transform:uppercase;">Team members</dt>
                    <dd style="margin:4px 0 0;font-size:14px;font-weight:700;">@_userCount</dd>
                </div>
            </dl>
        </div>

    </div>
}

@code {
    private string _name = "", _slug = "", _plan = "starter", _tenantId = "";
    private int _brandCount, _userCount;
    private DateTimeOffset _createdAt;
    private bool _loading = true, _saving, _saved, _isAdmin;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await LoadMe();
        await LoadTenant();
    }

    private async Task LoadMe()
    {
        try
        {
            var me = await Http.GetFromJsonAsync<ApiWrapper<MeData>>("api/v1/auth/me");
            _isAdmin = me?.Data?.Role == "TenantAdmin";
        }
        catch { }
    }

    private async Task LoadTenant()
    {
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiWrapper<TenantData>>("api/v1/tenant");
            if (resp?.Data is { } d)
            {
                _name = d.Name;
                _slug = d.Slug;
                _plan = d.Plan;
                _tenantId = d.Id.ToString();
                _brandCount = d.BrandCount;
                _userCount = d.UserCount;
                _createdAt = d.CreatedAt;
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private async Task Save()
    {
        _error = null;
        _saved = false;
        _saving = true;
        try
        {
            var resp = await Http.PutAsJsonAsync("api/v1/tenant", new { Name = _name });
            if (resp.IsSuccessStatusCode)
            {
                var body = await resp.Content.ReadFromJsonAsync<ApiWrapper<SlugData>>();
                _slug = body?.Data?.Slug ?? _slug;
                _saved = true;
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                _error = ExtractError(body);
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }

    private static string ExtractError(string json)
    {
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            if (doc.RootElement.TryGetProperty("error", out var e)) return e.GetString() ?? "Error";
        }
        catch { }
        return "Request failed";
    }

    private class TenantData
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = "";
        public string Slug { get; set; } = "";
        public string Plan { get; set; } = "starter";
        public int BrandCount { get; set; }
        public int UserCount { get; set; }
        public DateTimeOffset CreatedAt { get; set; }
    }

    private class MeData { public string? Role { get; set; } }
    private class SlugData { public string? Slug { get; set; } }
    private record ApiWrapper<T>(bool Success, T? Data);
}
