@page "/team"
@attribute [Authorize]
@inject HttpClient Http

<PageTitle>Team — Nucleus</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Team</h1>
        <p class="page-subtitle">Manage team members and their access levels</p>
    </div>
    @if (_isAdmin)
    {
        <button class="btn-primary" @onclick="() => _showInvite = true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Invite member
        </button>
    }
</div>

@if (_error != null)
{
    <div class="auth-error" style="margin-bottom:16px;">@_error</div>
}

@if (_successMsg != null)
{
    <div style="margin-bottom:16px;padding:12px 16px;background:rgba(16,185,129,0.08);
                border:1px solid rgba(16,185,129,0.2);border-radius:var(--radius);
                color:#10b981;font-weight:600;">@_successMsg</div>
}

<!-- Invite panel -->
@if (_showInvite)
{
    <div style="background:var(--color-surface);border:1px solid var(--color-border);
                border-radius:var(--radius);padding:28px;max-width:560px;margin-bottom:32px;">
        <h3 style="font-size:16px;font-weight:700;margin:0 0 20px;">Invite team member</h3>

        @if (_inviteError != null)
        {
            <div class="auth-error" style="margin-bottom:16px;">@_inviteError</div>
        }

        <div class="form-row">
            <div class="form-group">
                <label>FIRST NAME</label>
                <input class="form-input" @bind="_inviteFirst" placeholder="Jane" />
            </div>
            <div class="form-group">
                <label>LAST NAME</label>
                <input class="form-input" @bind="_inviteLast" placeholder="Smith" />
            </div>
        </div>
        <div class="form-group">
            <label>EMAIL</label>
            <input class="form-input" type="email" @bind="_inviteEmail" placeholder="jane@company.com" />
        </div>
        <div class="form-group">
            <label>ROLE</label>
            <select class="form-input" @bind="_inviteRole">
                <option value="BrandEditor">Brand Editor</option>
                <option value="TenantAdmin">Admin</option>
            </select>
        </div>

        <div style="display:flex;gap:12px;margin-top:8px;">
            <button class="btn-primary" @onclick="InviteUser" disabled="@_inviting">
                @(_inviting ? "Inviting…" : "Send invite")
            </button>
            <button class="btn-secondary" @onclick="() => { _showInvite = false; _inviteError = null; }">Cancel</button>
        </div>

        @if (_tempPassword != null)
        {
            <div style="margin-top:16px;padding:12px 16px;background:rgba(99,102,241,0.08);
                        border:1px solid rgba(99,102,241,0.25);border-radius:var(--radius);">
                <p style="font-size:13px;color:var(--color-muted);margin:0 0 6px;">Temporary password (share securely — shown once):</p>
                <code style="font-size:14px;font-weight:700;color:var(--color-text);word-break:break-all;">@_tempPassword</code>
            </div>
        }
    </div>
}

<!-- Member table -->
@if (_loading)
{
    <div class="loading-state"><div class="spinner spinner--lg"></div></div>
}
else if (_members.Count == 0)
{
    <div style="padding:48px;text-align:center;color:var(--color-muted);">No team members yet.</div>
}
else
{
    <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius);overflow:hidden;">
        <table style="width:100%;border-collapse:collapse;">
            <thead>
                <tr style="border-bottom:1px solid var(--color-border);background:rgba(0,0,0,0.02);">
                    <th style="padding:12px 20px;text-align:left;font-size:11px;font-weight:700;letter-spacing:.05em;color:var(--color-muted);text-transform:uppercase;">Name</th>
                    <th style="padding:12px 20px;text-align:left;font-size:11px;font-weight:700;letter-spacing:.05em;color:var(--color-muted);text-transform:uppercase;">Email</th>
                    <th style="padding:12px 20px;text-align:left;font-size:11px;font-weight:700;letter-spacing:.05em;color:var(--color-muted);text-transform:uppercase;">Role</th>
                    <th style="padding:12px 20px;text-align:left;font-size:11px;font-weight:700;letter-spacing:.05em;color:var(--color-muted);text-transform:uppercase;">Joined</th>
                    @if (_isAdmin) { <th style="padding:12px 20px;"></th> }
                </tr>
            </thead>
            <tbody>
                @foreach (var m in _members)
                {
                    <tr style="border-bottom:1px solid var(--color-border);">
                        <td style="padding:16px 20px;font-weight:600;">@m.FirstName @m.LastName</td>
                        <td style="padding:16px 20px;color:var(--color-muted);font-size:14px;">@m.Email</td>
                        <td style="padding:16px 20px;">
                            @if (_isAdmin && m.Id != _currentUserId)
                            {
                                <select style="border:1px solid var(--color-border);border-radius:6px;padding:4px 8px;font-size:13px;background:var(--color-surface);color:var(--color-text);"
                                        value="@m.Role"
                                        @onchange="e => ChangeRole(m, e.Value?.ToString() ?? m.Role)">
                                    <option value="BrandEditor">Brand Editor</option>
                                    <option value="TenantAdmin">Admin</option>
                                </select>
                            }
                            else
                            {
                                <span style="font-size:13px;padding:3px 10px;border-radius:999px;
                                             background:@(m.Role == "TenantAdmin" ? "rgba(99,102,241,0.1)" : "rgba(0,0,0,0.06)");
                                             color:@(m.Role == "TenantAdmin" ? "#6366f1" : "var(--color-muted)")">
                                    @(m.Role == "TenantAdmin" ? "Admin" : "Editor")
                                </span>
                            }
                        </td>
                        <td style="padding:16px 20px;font-size:13px;color:var(--color-muted);">@m.CreatedAt.ToString("MMM d, yyyy")</td>
                        @if (_isAdmin)
                        {
                            <td style="padding:16px 20px;text-align:right;">
                                @if (m.Id != _currentUserId)
                                {
                                    <button @onclick="() => RemoveUser(m)"
                                            style="font-size:13px;color:#ef4444;background:none;border:none;cursor:pointer;padding:4px 8px;border-radius:4px;">
                                        Remove
                                    </button>
                                }
                                else
                                {
                                    <span style="font-size:13px;color:var(--color-muted);">You</span>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<TeamMember> _members = [];
    private bool _loading = true;
    private bool _isAdmin;
    private Guid _currentUserId;
    private string? _error, _successMsg, _inviteError, _tempPassword;
    private bool _showInvite, _inviting;
    private string _inviteEmail = "", _inviteFirst = "", _inviteLast = "", _inviteRole = "BrandEditor";

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrentUser();
        await LoadMembers();
    }

    private async Task LoadCurrentUser()
    {
        try
        {
            var me = await Http.GetFromJsonAsync<ApiWrapper<MeData>>("api/v1/auth/me");
            if (me?.Data != null)
            {
                _currentUserId = me.Data.Id;
                _isAdmin = me.Data.Role == "TenantAdmin";
            }
        }
        catch { }
    }

    private async Task LoadMembers()
    {
        _loading = true;
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiWrapper<List<TeamMember>>>("api/v1/users");
            _members = resp?.Data ?? [];
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private async Task InviteUser()
    {
        _inviteError = null;
        _tempPassword = null;

        if (string.IsNullOrWhiteSpace(_inviteEmail) || string.IsNullOrWhiteSpace(_inviteFirst) || string.IsNullOrWhiteSpace(_inviteLast))
        {
            _inviteError = "All fields are required.";
            return;
        }

        _inviting = true;
        try
        {
            var resp = await Http.PostAsJsonAsync("api/v1/users/invite", new
            {
                Email = _inviteEmail.Trim(),
                FirstName = _inviteFirst.Trim(),
                LastName = _inviteLast.Trim(),
                Role = _inviteRole,
            });

            if (resp.IsSuccessStatusCode)
            {
                var body = await resp.Content.ReadFromJsonAsync<ApiWrapper<InviteResult>>();
                _tempPassword = body?.Data?.TempPassword;
                _successMsg = $"{_inviteFirst} {_inviteLast} has been added to your team.";
                _inviteEmail = _inviteFirst = _inviteLast = "";
                _inviteRole = "BrandEditor";
                await LoadMembers();
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                _inviteError = ExtractError(body);
            }
        }
        catch (Exception ex) { _inviteError = ex.Message; }
        finally { _inviting = false; }
    }

    private async Task ChangeRole(TeamMember member, string newRole)
    {
        _error = null;
        var resp = await Http.PutAsJsonAsync($"api/v1/users/{member.Id}/role", new { Role = newRole });
        if (resp.IsSuccessStatusCode)
        {
            member.Role = newRole;
            _successMsg = $"{member.FirstName}'s role updated.";
        }
        else
        {
            _error = $"Failed to update role ({(int)resp.StatusCode})";
        }
    }

    private async Task RemoveUser(TeamMember member)
    {
        _error = null;
        var resp = await Http.DeleteAsync($"api/v1/users/{member.Id}");
        if (resp.IsSuccessStatusCode)
        {
            _members.Remove(member);
            _successMsg = $"{member.FirstName} {member.LastName} has been removed.";
        }
        else
        {
            _error = $"Failed to remove user ({(int)resp.StatusCode})";
        }
    }

    private static string ExtractError(string json)
    {
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            if (doc.RootElement.TryGetProperty("error", out var e)) return e.GetString() ?? "Error";
        }
        catch { }
        return "Request failed";
    }

    private class TeamMember
    {
        public Guid Id { get; set; }
        public string Email { get; set; } = "";
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string Role { get; set; } = "";
        public DateTimeOffset CreatedAt { get; set; }
    }

    private class MeData
    {
        public Guid Id { get; set; }
        public string Role { get; set; } = "";
    }

    private class InviteResult
    {
        public string? TempPassword { get; set; }
    }

    private record ApiWrapper<T>(bool Success, T? Data);
}
