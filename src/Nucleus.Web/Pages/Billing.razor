@page "/billing"
@attribute [Authorize]
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Billing — Nucleus</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Billing</h1>
        <p class="page-subtitle">Manage your subscription</p>
    </div>
</div>

@if (_success)
{
    <div style="padding:16px;background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.2);border-radius:var(--radius);color:#10b981;font-weight:600;margin-bottom:24px;">
        Subscription activated — welcome to Nucleus Pro!
    </div>
}
@if (_canceled)
{
    <div style="padding:16px;background:rgba(245,158,11,0.08);border:1px solid rgba(245,158,11,0.3);border-radius:var(--radius);color:#f59e0b;font-weight:600;margin-bottom:24px;">
        Checkout canceled — no charge was made.
    </div>
}

@if (_loading)
{
    <div class="loading-state"><div class="spinner spinner--lg"></div></div>
}
else
{
    <!-- Current plan card -->
    <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius);padding:28px;max-width:560px;margin-bottom:24px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
            <div>
                <div style="font-size:13px;font-weight:700;color:var(--color-muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px;">Current plan</div>
                <div style="font-size:28px;font-weight:800;text-transform:capitalize;">@_plan</div>
            </div>
            <div style="padding:6px 14px;border-radius:999px;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;background:@StatusBg();color:@StatusColor();">
                @(_status ?? "—")
            </div>
        </div>

        @if (_plan == "starter")
        {
            <p style="font-size:14px;color:var(--color-muted);margin:0 0 20px;">
                You're on the free Starter plan. Upgrade to Pro for unlimited brands, advanced analytics, and priority support.
            </p>

            @if (!_stripeConfigured)
            {
                <div style="padding:12px 16px;background:rgba(245,158,11,0.08);border:1px solid rgba(245,158,11,0.3);border-radius:var(--radius);color:#f59e0b;font-size:13px;">
                    Stripe is not yet configured. Add <strong>STRIPE_SECRET_KEY</strong> and <strong>STRIPE_PRICE_ID</strong> to your Railway environment.
                </div>
            }
            else
            {
                <button class="btn-primary" @onclick="Upgrade" disabled="@_working">
                    @(_working ? "Redirecting…" : "Upgrade to Pro →")
                </button>
            }
        }
        else
        {
            <p style="font-size:14px;color:var(--color-muted);margin:0 0 20px;">
                You have an active Pro subscription. Use the portal to update your payment method, download invoices, or cancel.
            </p>
            <button class="btn-secondary" @onclick="OpenPortal" disabled="@_working">
                @(_working ? "Opening…" : "Manage billing →")
            </button>
        }
    </div>

    <!-- Plan comparison -->
    <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius);overflow:hidden;max-width:560px;">
        <div style="padding:16px 20px;border-bottom:1px solid var(--color-border);font-size:13px;font-weight:700;color:var(--color-muted);text-transform:uppercase;letter-spacing:.05em;">
            Plan comparison
        </div>
        @foreach (var (feature, starter, pro) in PlanFeatures)
        {
            <div style="display:grid;grid-template-columns:1fr auto auto;gap:16px;padding:12px 20px;border-bottom:1px solid var(--color-border);align-items:center;">
                <span style="font-size:14px;">@feature</span>
                <span style="font-size:13px;color:var(--color-muted);text-align:center;min-width:70px;">@starter</span>
                <span style="font-size:13px;font-weight:600;color:#6366f1;text-align:center;min-width:70px;">@pro</span>
            </div>
        }
        <div style="display:grid;grid-template-columns:1fr auto auto;gap:16px;padding:12px 20px;align-items:center;">
            <span style="font-size:13px;font-weight:700;color:var(--color-muted);">Plan</span>
            <span style="font-size:13px;color:var(--color-muted);text-align:center;min-width:70px;">Free</span>
            <span style="font-size:13px;font-weight:700;color:#6366f1;text-align:center;min-width:70px;">Pro</span>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(_error))
{
    <div class="auth-error" style="margin-top:16px;max-width:560px;">@_error</div>
}

@code {
    private string _plan = "starter";
    private string? _status;
    private bool _stripeConfigured;
    private bool _loading = true, _working;
    private bool _success, _canceled;
    private string? _error;

    private static readonly (string Feature, string Starter, string Pro)[] PlanFeatures =
    [
        ("Brands", "1", "Unlimited"),
        ("GHL contact sync", "✓", "✓"),
        ("Keyword rank tracking", "50 keywords", "Unlimited"),
        ("Email campaigns", "500/mo", "Unlimited"),
        ("Analytics dashboard", "✓", "✓"),
        ("WordPress publishing", "✓", "✓"),
        ("Priority support", "—", "✓"),
    ];

    protected override async Task OnInitializedAsync()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        _success = query["success"] == "1";
        _canceled = query["canceled"] == "1";

        try
        {
            var resp = await Http.GetFromJsonAsync<ApiWrapper<SubData>>("api/v1/billing/subscription");
            if (resp?.Data != null)
            {
                _plan = resp.Data.Plan;
                _status = resp.Data.SubscriptionStatus;
                _stripeConfigured = resp.Data.StripeConfigured;
            }
        }
        catch { }
        finally { _loading = false; }
    }

    private async Task Upgrade()
    {
        _working = true;
        _error = null;
        try
        {
            var resp = await Http.PostAsJsonAsync("api/v1/billing/checkout", new { });
            if (resp.IsSuccessStatusCode)
            {
                var data = await resp.Content.ReadFromJsonAsync<ApiWrapper<UrlData>>();
                if (!string.IsNullOrEmpty(data?.Data?.Url))
                    Nav.NavigateTo(data.Data.Url, forceLoad: true);
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                _error = ExtractError(body);
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _working = false; }
    }

    private async Task OpenPortal()
    {
        _working = true;
        _error = null;
        try
        {
            var resp = await Http.PostAsync("api/v1/billing/portal", null);
            if (resp.IsSuccessStatusCode)
            {
                var data = await resp.Content.ReadFromJsonAsync<ApiWrapper<UrlData>>();
                if (!string.IsNullOrEmpty(data?.Data?.Url))
                    Nav.NavigateTo(data.Data.Url, forceLoad: true);
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                _error = ExtractError(body);
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _working = false; }
    }

    private string StatusBg() => _status switch
    {
        "active" or "trialing" => "rgba(16,185,129,0.1)",
        "past_due" => "rgba(245,158,11,0.1)",
        "canceled" => "rgba(239,68,68,0.1)",
        _ => "rgba(0,0,0,0.06)",
    };

    private string StatusColor() => _status switch
    {
        "active" or "trialing" => "#10b981",
        "past_due" => "#f59e0b",
        "canceled" => "#ef4444",
        _ => "var(--color-muted)",
    };

    private static string ExtractError(string json)
    {
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            if (doc.RootElement.TryGetProperty("error", out var e)) return e.GetString() ?? "Error";
        }
        catch { }
        return "Request failed";
    }

    private class SubData
    {
        public string Plan { get; set; } = "starter";
        public string? SubscriptionStatus { get; set; }
        public bool StripeConfigured { get; set; }
    }

    private class UrlData { public string? Url { get; set; } }
    private record ApiWrapper<T>(bool Success, T? Data);
}
