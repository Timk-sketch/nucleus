@page "/content/templates"
@attribute [Authorize]
@layout ContentLayout
@inject HttpClient Http

<PageTitle>Content Templates — Content Hub</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Content Templates</h1>
        <p class="page-subtitle">Reusable prompt templates that guide AI content generation. Brand-specific or shared globally.</p>
    </div>
</div>

@if (_brandsLoading)
{
    <div class="loading-state"><div class="spinner spinner--lg"></div></div>
}
else if (_brands.Count == 0)
{
    <div class="empty-state">No brands yet. <a href="/brands">Add a brand</a> to get started.</div>
}
else
{
    <!-- Brand Picker -->
    <div style="display:flex;gap:10px;margin-bottom:24px;flex-wrap:wrap;">
        @foreach (var b in _brands)
        {
            <button @onclick="() => SelectBrand(b)"
                    style="padding:8px 16px;border-radius:999px;border:2px solid @(_selectedBrand?.Id == b.Id ? "#3b82f6" : "var(--color-border)");
                           background:@(_selectedBrand?.Id == b.Id ? "rgba(59,130,246,0.1)" : "var(--color-surface)");
                           color:@(_selectedBrand?.Id == b.Id ? "#3b82f6" : "var(--color-text)");
                           font-size:13px;font-weight:600;cursor:pointer;">
                @b.Name
            </button>
        }
    </div>

    @if (_selectedBrand != null)
    {
        <div style="display:grid;grid-template-columns:400px 1fr;gap:24px;max-width:1100px;">

            <!-- Create Template Form -->
            <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius);padding:24px;height:fit-content;">
                <h3 style="font-size:14px;font-weight:700;margin:0 0 16px;">Create Template</h3>

                @if (_createError != null)
                {
                    <div class="auth-error" style="margin-bottom:12px;">@_createError</div>
                }
                @if (_createSuccess != null)
                {
                    <div style="margin-bottom:12px;padding:10px 14px;background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.2);border-radius:var(--radius);color:#10b981;font-weight:600;">
                        @_createSuccess
                    </div>
                }

                <div class="form-group">
                    <label>TEMPLATE NAME</label>
                    <input class="form-input" @bind="_name" placeholder="e.g. Montana Service Page v1" />
                </div>

                <div class="form-group">
                    <label>PAGE TYPE</label>
                    <select class="form-input" @bind="_pageType">
                        <option value="blog_post">Blog Post</option>
                        <option value="landing_page">Landing Page</option>
                        <option value="service_page">Service Page</option>
                        <option value="pillar">Pillar Article</option>
                        <option value="cluster">Cluster Article</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>TEMPLATE BODY</label>
                    <div style="font-size:11px;color:var(--color-muted);margin-bottom:6px;">
                        Placeholders: <code>&#123;&#123;keyword&#125;&#125;</code>  <code>&#123;&#123;brand&#125;&#125;</code>  <code>&#123;&#123;service&#125;&#125;</code>  <code>&#123;&#123;location&#125;&#125;</code>
                    </div>
                    <textarea class="form-input" @bind="_body" rows="8"
                              style="resize:vertical;font-size:13px;font-family:monospace;"
                              placeholder="Write a comprehensive {{page_type}} about {{keyword}} for {{brand}}. Include an introduction, 3 main sections with subheadings, a FAQ section, and a conclusion with CTA..."></textarea>
                </div>

                <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;">
                    <input type="checkbox" id="isGlobal" @bind="_isGlobal" style="width:16px;height:16px;cursor:pointer;" />
                    <label for="isGlobal" style="font-size:13px;font-weight:600;cursor:pointer;">
                        Share across all brands (global)
                    </label>
                </div>

                <button class="btn-primary" @onclick="CreateTemplate"
                        disabled="@_creating" style="width:100%;justify-content:center;">
                    @(_creating ? "Creating…" : "Create Template")
                </button>
            </div>

            <!-- Templates List -->
            <div>
                @if (_loading)
                {
                    <div class="loading-state"><div class="spinner spinner--lg"></div></div>
                }
                else if (_templates.Count == 0)
                {
                    <div class="empty-state">
                        No templates yet. Create your first template on the left.
                    </div>
                }
                else
                {
                    <!-- Filter by Page Type -->
                    <div style="display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap;">
                        <button @onclick='() => { _typeFilter = ""; }' class="btn-secondary"
                                style="@(_typeFilter == "" ? "background:rgba(59,130,246,0.1);color:#3b82f6;border-color:#3b82f6;" : "")font-size:12px;padding:5px 12px;">
                            All
                        </button>
                        @foreach (var type in new[] { "blog_post", "landing_page", "service_page", "pillar", "cluster" })
                        {
                            <button @onclick="() => { _typeFilter = type; }" class="btn-secondary"
                                    style="@(_typeFilter == type ? "background:rgba(59,130,246,0.1);color:#3b82f6;border-color:#3b82f6;" : "")font-size:12px;padding:5px 12px;">
                                @type.Replace("_", " ")
                            </button>
                        }
                    </div>

                    <div style="display:flex;flex-direction:column;gap:12px;">
                        @foreach (var tmpl in FilteredTemplates())
                        {
                            <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius);padding:18px 20px;">
                                <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;margin-bottom:8px;">
                                    <div>
                                        <div style="font-weight:700;font-size:14px;">@tmpl.Name</div>
                                        <div style="font-size:12px;color:var(--color-muted);margin-top:3px;display:flex;gap:8px;">
                                            <span>@tmpl.PageType.Replace("_", " ")</span>
                                            @if (tmpl.IsGlobal)
                                            {
                                                <span style="padding:1px 8px;border-radius:999px;font-size:11px;font-weight:700;
                                                             background:rgba(99,102,241,0.1);color:#6366f1;">Global</span>
                                            }
                                            @if (!tmpl.IsActive)
                                            {
                                                <span style="padding:1px 8px;border-radius:999px;font-size:11px;font-weight:700;
                                                             background:rgba(0,0,0,0.06);color:var(--color-muted);">Inactive</span>
                                            }
                                        </div>
                                    </div>
                                    <span style="font-size:11px;color:var(--color-muted);flex-shrink:0;">
                                        @tmpl.CreatedAt.ToString("MMM d, yyyy")
                                    </span>
                                </div>
                                <div style="font-size:13px;color:var(--color-muted);line-height:1.6;
                                            max-height:80px;overflow:hidden;text-overflow:ellipsis;">
                                    @tmpl.Body[..Math.Min(200, tmpl.Body.Length)]@(tmpl.Body.Length > 200 ? "…" : "")
                                </div>
                                <div style="margin-top:10px;">
                                    <a href="/content/generator?templateId=@tmpl.Id"
                                       style="font-size:13px;color:#3b82f6;text-decoration:none;font-weight:600;">
                                        Use template →
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
}

@code {
    private List<BrandItem> _brands = [];
    private BrandItem? _selectedBrand;
    private bool _brandsLoading = true, _loading, _creating;
    private List<ContentTemplateDto> _templates = [];
    private string _name = "", _pageType = "blog_post", _body = "", _typeFilter = "";
    private bool _isGlobal;
    private string? _createError, _createSuccess;

    protected override async Task OnInitializedAsync()
    {
        var resp = await Http.GetFromJsonAsync<ApiWrap<List<BrandItem>>>("api/v1/brands");
        _brands = resp?.Data ?? [];
        _brandsLoading = false;
        if (_brands.Count > 0) await SelectBrand(_brands[0]);
    }

    private async Task SelectBrand(BrandItem brand)
    {
        _selectedBrand = brand;
        _createError = _createSuccess = null;
        await LoadTemplates();
    }

    private async Task LoadTemplates()
    {
        if (_selectedBrand is null) return;
        _loading = true;
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiWrap<List<ContentTemplateDto>>>(
                $"api/content/templates?brandId={_selectedBrand.Id}&activeOnly=false");
            _templates = resp?.Data ?? [];
        }
        catch { }
        finally { _loading = false; }
    }

    private async Task CreateTemplate()
    {
        if (string.IsNullOrWhiteSpace(_name)) { _createError = "Template name is required."; return; }
        if (string.IsNullOrWhiteSpace(_body)) { _createError = "Template body is required."; return; }

        _createError = null; _createSuccess = null; _creating = true;

        try
        {
            var resp = await Http.PostAsJsonAsync("api/content/templates", new
            {
                BrandId = _selectedBrand!.Id,
                Name = _name,
                PageType = _pageType,
                Body = _body,
                IsGlobal = _isGlobal,
                IsActive = true,
            });

            if (resp.IsSuccessStatusCode)
            {
                _createSuccess = $"Template '{_name}' created.";
                _name = _body = "";
                _isGlobal = false;
                await LoadTemplates();
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                _createError = ExtractError(body);
            }
        }
        catch (Exception ex) { _createError = ex.Message; }
        finally { _creating = false; }
    }

    private IEnumerable<ContentTemplateDto> FilteredTemplates()
    {
        if (string.IsNullOrEmpty(_typeFilter)) return _templates;
        return _templates.Where(t => t.PageType == _typeFilter);
    }

    private static string ExtractError(string json)
    {
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            if (doc.RootElement.TryGetProperty("error", out var e)) return e.GetString() ?? "Error";
        }
        catch { }
        return "Request failed";
    }

    // ── DTOs ──
    private class BrandItem { public Guid Id { get; set; } public string Name { get; set; } = ""; }

    private class ContentTemplateDto
    {
        public Guid Id { get; set; }
        public Guid BrandId { get; set; }
        public string Name { get; set; } = "";
        public string PageType { get; set; } = "";
        public string Body { get; set; } = "";
        public bool IsGlobal { get; set; }
        public bool IsActive { get; set; }
        public DateTimeOffset CreatedAt { get; set; }
    }

    private record ApiWrap<T>(bool Success, T? Data);
}
