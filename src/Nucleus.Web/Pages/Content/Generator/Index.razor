@page "/content/generator"
@attribute [Authorize]
@layout ContentLayout
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>AI Generator — Content Hub</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">AI Content Generator</h1>
        <p class="page-subtitle">Generate keyword-targeted content using Claude AI. Starter plan: 5 generations/month.</p>
    </div>
</div>

@if (_brandsLoading)
{
    <div class="loading-state"><div class="spinner spinner--lg"></div></div>
}
else if (_brands.Count == 0)
{
    <div class="empty-state">No brands yet. <a href="/brands">Add a brand</a> to get started.</div>
}
else
{
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;max-width:1100px;">

        <!-- Left: Generator Form -->
        <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius);padding:28px;">
            <h3 style="font-size:14px;font-weight:700;margin:0 0 20px;">Generator Settings</h3>

            @if (_error != null)
            {
                <div class="auth-error" style="margin-bottom:16px;">@_error</div>
            }
            @if (_planLimit)
            {
                <div style="margin-bottom:16px;padding:12px 16px;background:rgba(245,158,11,0.08);border:1px solid rgba(245,158,11,0.3);border-radius:var(--radius);font-size:13px;">
                    <strong style="color:#f59e0b;">Plan limit reached.</strong>
                    Starter plan allows 5 AI generations per month.
                    <a href="/billing" style="color:#3b82f6;margin-left:6px;">Upgrade to Pro →</a>
                </div>
            }

            <!-- Brand -->
            <div class="form-group">
                <label>BRAND</label>
                <select class="form-input" @bind="_brandId">
                    <option value="">Select brand…</option>
                    @foreach (var b in _brands)
                    {
                        <option value="@b.Id">@b.Name</option>
                    }
                </select>
            </div>

            <!-- Title -->
            <div class="form-group">
                <label>CONTENT TITLE</label>
                <input class="form-input" @bind="_title"
                       placeholder="e.g. How to Register an LLC in Montana" />
            </div>

            <!-- Page Type -->
            <div class="form-group">
                <label>PAGE TYPE</label>
                <select class="form-input" @bind="_pageType">
                    <option value="blog_post">Blog Post</option>
                    <option value="landing_page">Landing Page</option>
                    <option value="service_page">Service Page</option>
                    <option value="pillar">Pillar Article</option>
                    <option value="cluster">Cluster Article</option>
                </select>
            </div>

            <!-- Focus Keyword -->
            <div class="form-group">
                <label>FOCUS KEYWORD <span class="label-hint">(optional)</span></label>
                <input class="form-input" @bind="_focusKeyword"
                       placeholder="e.g. montana llc registration" />
            </div>

            <!-- Word Count -->
            <div class="form-group">
                <label>TARGET WORD COUNT</label>
                <select class="form-input" @bind="_wordCount">
                    <option value="400">~400 words (Short)</option>
                    <option value="800">~800 words (Standard)</option>
                    <option value="1200">~1,200 words (Long)</option>
                    <option value="2000">~2,000 words (Pillar)</option>
                </select>
            </div>

            <!-- Custom Prompt -->
            <div class="form-group">
                <label>CUSTOM INSTRUCTIONS <span class="label-hint">(optional)</span></label>
                <textarea class="form-input" @bind="_customPrompt" rows="3"
                          style="resize:vertical;font-size:13px;"
                          placeholder="Any specific instructions for the AI…"></textarea>
            </div>

            <button class="btn-primary" @onclick="Generate"
                    disabled="@(_generating || _planLimit)"
                    style="width:100%;margin-top:8px;justify-content:center;">
                @if (_generating)
                {
                    <span class="spinner" style="width:16px;height:16px;border-width:2px;margin-right:8px;"></span>
                    <span>Generating…</span>
                }
                else
                {
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:8px;">
                        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                    </svg>
                    <span>Generate Content</span>
                }
            </button>
        </div>

        <!-- Right: Generated Output -->
        <div>
            @if (_result == null && !_generating)
            {
                <div style="height:100%;min-height:300px;background:var(--color-surface);border:2px dashed var(--color-border);border-radius:var(--radius);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;color:var(--color-muted);padding:40px;text-align:center;">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity=".4">
                        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                    </svg>
                    <div style="font-size:14px;">Generated content will appear here</div>
                    <div style="font-size:12px;">Fill in the settings and click Generate</div>
                </div>
            }
            else if (_generating)
            {
                <div style="min-height:300px;background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;padding:40px;text-align:center;">
                    <div class="spinner spinner--lg"></div>
                    <div style="font-size:14px;color:var(--color-muted);">Claude is writing your content…</div>
                </div>
            }
            else if (_result != null)
            {
                <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius);overflow:hidden;">
                    <!-- Header -->
                    <div style="padding:16px 20px;border-bottom:1px solid var(--color-border);display:flex;justify-content:space-between;align-items:center;">
                        <div>
                            <div style="font-weight:700;font-size:15px;">@_result.Title</div>
                            <div style="font-size:12px;color:var(--color-muted);margin-top:3px;">
                                @_result.WordCount words ·
                                <span style="padding:2px 8px;border-radius:999px;font-size:11px;font-weight:700;background:rgba(16,185,129,0.1);color:#10b981;">
                                    Draft
                                </span>
                            </div>
                        </div>
                        <div style="display:flex;gap:8px;">
                            <button @onclick="NavigateToLibrary"
                                    class="btn-secondary" style="font-size:12px;padding:6px 14px;">
                                View Library →
                            </button>
                        </div>
                    </div>
                    <!-- SEO Meta -->
                    @if (!string.IsNullOrEmpty(_result.MetaDescription))
                    {
                        <div style="padding:12px 20px;background:rgba(59,130,246,0.05);border-bottom:1px solid var(--color-border);">
                            <div style="font-size:11px;font-weight:700;color:#3b82f6;text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px;">Meta Description</div>
                            <div style="font-size:13px;color:var(--color-muted);">@_result.MetaDescription</div>
                        </div>
                    }
                    <!-- Content Preview -->
                    <div style="padding:20px;max-height:420px;overflow-y:auto;">
                        <div style="font-size:13px;line-height:1.7;color:var(--color-text);">
                            @((MarkupString)(_result.HtmlContent ?? ""))
                        </div>
                    </div>
                    <!-- Actions -->
                    <div style="padding:14px 20px;border-top:1px solid var(--color-border);display:flex;gap:10px;background:rgba(0,0,0,0.01);">
                        <button @onclick="SubmitForReview" class="btn-primary" style="font-size:13px;padding:8px 16px;">
                            Submit for Review
                        </button>
                        <button @onclick="Generate" class="btn-secondary" style="font-size:13px;padding:8px 16px;">
                            Regenerate
                        </button>
                    </div>
                </div>

                @if (_reviewSuccess)
                {
                    <div style="margin-top:12px;padding:12px 16px;background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.2);border-radius:var(--radius);color:#10b981;font-size:13px;font-weight:600;">
                        ✓ Submitted for review. Check the <a href="/content/queue" style="color:#10b981;">Review Queue</a>.
                    </div>
                }
            }
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery] private string? BrandId { get; set; }
    [SupplyParameterFromQuery] private string? KeywordId { get; set; }
    [SupplyParameterFromQuery] private string? Keyword { get; set; }

    private List<BrandItem> _brands = [];
    private bool _brandsLoading = true, _generating;
    private string _brandId = "", _title = "", _pageType = "blog_post", _focusKeyword = "", _customPrompt = "";
    private int _wordCount = 800;
    private string? _error;
    private bool _planLimit, _reviewSuccess;
    private ContentPageResult? _result;

    protected override async Task OnInitializedAsync()
    {
        var resp = await Http.GetFromJsonAsync<ApiWrap<List<BrandItem>>>("api/v1/brands");
        _brands = resp?.Data ?? [];
        _brandsLoading = false;

        if (!string.IsNullOrEmpty(BrandId)) _brandId = BrandId;
        else if (_brands.Count > 0) _brandId = _brands[0].Id.ToString();

        if (!string.IsNullOrEmpty(Keyword)) _focusKeyword = Uri.UnescapeDataString(Keyword);
    }

    private async Task Generate()
    {
        if (string.IsNullOrWhiteSpace(_brandId)) { _error = "Please select a brand."; return; }
        if (string.IsNullOrWhiteSpace(_title)) { _error = "Please enter a content title."; return; }

        _error = null; _planLimit = false; _reviewSuccess = false; _generating = true;

        try
        {
            var payload = new
            {
                BrandId = Guid.Parse(_brandId),
                Title = _title,
                PageType = _pageType,
                FocusKeyword = string.IsNullOrWhiteSpace(_focusKeyword) ? null : _focusKeyword,
                KeywordId = (string.IsNullOrWhiteSpace(KeywordId) || !Guid.TryParse(KeywordId, out var kid))
                    ? (Guid?)null : kid,
                WordCount = _wordCount,
                CustomPrompt = string.IsNullOrWhiteSpace(_customPrompt) ? null : _customPrompt,
            };

            var resp = await Http.PostAsJsonAsync("api/content/generate", payload);
            var body = await resp.Content.ReadAsStringAsync();

            if (resp.StatusCode == System.Net.HttpStatusCode.PaymentRequired)
            {
                _planLimit = true;
                _error = ExtractError(body);
            }
            else if (!resp.IsSuccessStatusCode)
            {
                _error = ExtractError(body);
            }
            else
            {
                var result = System.Text.Json.JsonSerializer.Deserialize<ApiWrap<ContentPageResult>>(
                    body, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                _result = result?.Data;
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _generating = false; }
    }

    private void NavigateToLibrary()
    {
        if (_result is null) return;
        Nav.NavigateTo("/content/library?brandId=" + _result.BrandId);
    }

    private async Task SubmitForReview()
    {
        if (_result == null) return;
        try
        {
            var resp = await Http.PutAsJsonAsync(
                $"api/content/pages/{_result.Id}/approve",
                new { Approve = false });
            if (resp.IsSuccessStatusCode) _reviewSuccess = true;
        }
        catch { }
    }

    private static string ExtractError(string json)
    {
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            if (doc.RootElement.TryGetProperty("error", out var e)) return e.GetString() ?? "Error";
        }
        catch { }
        return "Request failed";
    }

    // ── DTOs ──
    private class BrandItem { public Guid Id { get; set; } public string Name { get; set; } = ""; }

    private class ContentPageResult
    {
        public Guid Id { get; set; }
        public Guid BrandId { get; set; }
        public string Title { get; set; } = "";
        public string Status { get; set; } = "";
        public string? HtmlContent { get; set; }
        public string? MetaDescription { get; set; }
        public int? WordCount { get; set; }
    }

    private record ApiWrap<T>(bool Success, T? Data);
}
