@page "/content"
@attribute [Authorize]
@layout ContentLayout

<PageTitle>Content Hub — Nucleus</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Content Hub</h1>
        <p class="page-subtitle">Plan, generate, and publish content that drives organic growth.</p>
    </div>
</div>

<div class="hub-feature-grid">
    <a href="/content/keywords" style="text-decoration:none;">
        <div class="hub-feature-card">
            <div class="hub-feature-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8"/>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
            </div>
            <div>
                <div class="hub-feature-name">Keyword Library</div>
                <div class="hub-feature-desc">Manage all tracked keywords per brand — with live rank positions and content coverage.</div>
            </div>
        </div>
    </a>
    <a href="/content/generator" style="text-decoration:none;">
        <div class="hub-feature-card">
            <div class="hub-feature-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                </svg>
            </div>
            <div>
                <div class="hub-feature-name">AI Generator</div>
                <div class="hub-feature-desc">Generate keyword-targeted blog posts, landing pages, and service pages using Claude AI.</div>
            </div>
        </div>
    </a>
    <a href="/content/calendar" style="text-decoration:none;">
        <div class="hub-feature-card">
            <div class="hub-feature-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                    <line x1="16" y1="2" x2="16" y2="6"/>
                    <line x1="8"  y1="2" x2="8"  y2="6"/>
                    <line x1="3"  y1="10" x2="21" y2="10"/>
                </svg>
            </div>
            <div>
                <div class="hub-feature-name">Editorial Calendar</div>
                <div class="hub-feature-desc">Visual calendar view of scheduled and published content — plan your content cadence.</div>
            </div>
        </div>
    </a>
    <a href="/content/library" style="text-decoration:none;">
        <div class="hub-feature-card">
            <div class="hub-feature-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                    <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                </svg>
            </div>
            <div>
                <div class="hub-feature-name">Content Library</div>
                <div class="hub-feature-desc">Browse and manage all generated and manually written content across every brand.</div>
            </div>
        </div>
    </a>
    <a href="/content/queue" style="text-decoration:none;">
        <div class="hub-feature-card">
            <div class="hub-feature-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="9 11 12 14 22 4"/>
                    <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
                </svg>
            </div>
            <div>
                <div class="hub-feature-name">Review Queue</div>
                <div class="hub-feature-desc">Approve or reject AI-generated content before it goes live. Full editorial workflow.</div>
            </div>
        </div>
    </a>
    <a href="/content/brand-voice" style="text-decoration:none;">
        <div class="hub-feature-card">
            <div class="hub-feature-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 20h9"/>
                    <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
                </svg>
            </div>
            <div>
                <div class="hub-feature-name">Brand Voice</div>
                <div class="hub-feature-desc">Define banned words and phrases that the AI generator will never use for this brand.</div>
            </div>
        </div>
    </a>
    <a href="/content/templates" style="text-decoration:none;">
        <div class="hub-feature-card">
            <div class="hub-feature-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="16" y1="13" x2="8" y2="13"/>
                    <line x1="16" y1="17" x2="8" y2="17"/>
                </svg>
            </div>
            <div>
                <div class="hub-feature-name">Templates</div>
                <div class="hub-feature-desc">Reusable prompt templates to guide AI generation — page-type specific and shareable across brands.</div>
            </div>
        </div>
    </a>
</div>
