@inherits LayoutComponentBase

<ShellLayout Hub="search" HubColor="#16a34a" HubName="Search Hub">
    <FocusMenu>
        <nav class="hub-focus-menu">
            <NavLink href="/search/rankings" class="hub-focus-item" Match="NavLinkMatch.All">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="20" x2="18" y2="10"/>
                    <line x1="12" y1="20" x2="12" y2="4"/>
                    <line x1="6"  y1="20" x2="6"  y2="14"/>
                </svg>
                Rankings
            </NavLink>
            <NavLink href="/search/history" class="hub-focus-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
                </svg>
                History
            </NavLink>
            <NavLink href="/search/alerts" class="hub-focus-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                    <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                </svg>
                Alerts
            </NavLink>
            <NavLink href="/search/clusters" class="hub-focus-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="18" cy="5"  r="3"/>
                    <circle cx="6"  cy="12" r="3"/>
                    <circle cx="18" cy="19" r="3"/>
                    <line x1="8.59"  y1="13.51" x2="15.42" y2="17.49"/>
                    <line x1="15.41" y1="6.51"  x2="8.59"  y2="10.49"/>
                </svg>
                Clusters
            </NavLink>
            <NavLink href="/search/gaps" class="hub-focus-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8"/>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    <line x1="11" y1="8"  x2="11"    y2="14"/>
                    <line x1="8"  y1="11" x2="14"    y2="11"/>
                </svg>
                Content Gaps
            </NavLink>
            <NavLink href="/search/performance" class="hub-focus-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                    <polyline points="17 8 12 3 7 8"/>
                    <line x1="12" y1="3" x2="12" y2="15"/>
                </svg>
                Performance
            </NavLink>
        </nav>
    </FocusMenu>
    <ChildContent>@Body</ChildContent>
</ShellLayout>
