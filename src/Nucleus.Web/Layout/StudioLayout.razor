@inherits LayoutComponentBase

<ShellLayout Hub="studio" HubColor="#ec4899" HubName="Studio Hub">
    <FocusMenu>
        <nav class="hub-focus-menu">
            <NavLink href="/studio" class="hub-focus-item" Match="NavLinkMatch.All">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="7" height="7"/>
                    <rect x="14" y="3" width="7" height="7"/>
                    <rect x="14" y="14" width="7" height="7"/>
                    <rect x="3" y="14" width="7" height="7"/>
                </svg>
                Overview
            </NavLink>
            <NavLink href="/studio/pages" class="hub-focus-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                    <line x1="3" y1="9" x2="21" y2="9"/>
                    <line x1="9" y1="9" x2="9" y2="21"/>
                </svg>
                Page Manager
            </NavLink>
            <NavLink href="/studio/design" class="hub-focus-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 20h9"/>
                    <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
                </svg>
                Design Studio
            </NavLink>
            <NavLink href="/studio/images" class="hub-focus-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                    <circle cx="8.5" cy="8.5" r="1.5"/>
                    <polyline points="21 15 16 10 5 21"/>
                </svg>
                Image Generator
            </NavLink>
            <NavLink href="/studio/assets" class="hub-focus-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
                </svg>
                Asset Library
            </NavLink>
        </nav>
    </FocusMenu>
    <ChildContent>@Body</ChildContent>
</ShellLayout>
