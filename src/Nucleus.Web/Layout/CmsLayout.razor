@inherits LayoutComponentBase

<ShellLayout Hub="cms" HubColor="#0ea5e9" HubName="CMS Hub">
    <FocusMenu>
        <nav class="hub-focus-menu">
            <NavLink href="/cms/sites" class="hub-focus-item" Match="NavLinkMatch.All">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                    <line x1="8" y1="21" x2="16" y2="21"/>
                    <line x1="12" y1="17" x2="12" y2="21"/>
                </svg>
                Sites
            </NavLink>
            <NavLink href="/cms/domains" class="hub-focus-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="2" y1="12" x2="22" y2="12"/>
                    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                </svg>
                Domains
            </NavLink>
            <NavLink href="/cms/analytics" class="hub-focus-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="20" x2="18" y2="10"/>
                    <line x1="12" y1="20" x2="12" y2="4"/>
                    <line x1="6" y1="20" x2="6" y2="14"/>
                </svg>
                Analytics
            </NavLink>
        </nav>
    </FocusMenu>
    <ChildContent>@Body</ChildContent>
</ShellLayout>
